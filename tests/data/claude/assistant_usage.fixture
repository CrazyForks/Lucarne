# Assistant message usage aliases plus result total_cost_usd.
OUT {"type":"system","subtype":"init","session_id":"sess-usage","model":"claude-sonnet-4"}
EXPECT_IN_CONTAINS "show usage"
OUT {"type":"assistant","message":{"id":"msg_usage","content":[{"type":"text","text":"Done"}],"usage":{"input_tokens":12,"output_tokens":5,"cache_read_input_tokens":4,"cache_creation_input_tokens":2}}}
OUT {"type":"result","subtype":"success","session_id":"sess-usage","result":"done","usage":{"input_tokens":12,"output_tokens":5,"cache_read_input_tokens":4,"cache_creation_input_tokens":2},"total_cost_usd":0.42}
EXIT 0
