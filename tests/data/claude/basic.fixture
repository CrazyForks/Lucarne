# Basic: init, single assistant text, result
OUT {"type":"system","subtype":"init","session_id":"sess-basic","model":"claude-sonnet-4"}
EXPECT_IN_CONTAINS "Hello Claude"
OUT {"type":"assistant","message":{"id":"msg_1","content":[{"type":"text","text":"Hi! How can I help?"}]}}
OUT {"type":"result","subtype":"success","session_id":"sess-basic","num_turns":1,"duration_ms":100,"usage":{"input_tokens":10,"output_tokens":6}}
EXIT 0
