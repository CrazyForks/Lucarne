# Codex interrupt + recovery: abort first turn, then accept a second turn.

EXPECT_IN_CONTAINS "\"method\":\"initialize\""
OUT {"jsonrpc":"2.0","id":0,"result":{}}
EXPECT_IN_CONTAINS "\"method\":\"initialized\""
EXPECT_IN_CONTAINS "thread/start"
OUT {"jsonrpc":"2.0","id":1,"result":{"threadId":"test-thread-interrupt"}}
EXPECT_IN_CONTAINS "first turn"
OUT {"jsonrpc":"2.0","method":"turn/started","params":{}}
OUT {"jsonrpc":"2.0","method":"item/started","params":{"item":{"type":"commandExecution","id":"cmd-interrupt","command":"sleep 30"}}}
EXPECT_IN_CONTAINS "turn/interrupt"
OUT {"jsonrpc":"2.0","method":"turn_aborted","params":{"error":{"message":"aborted"}}}
EXPECT_IN_CONTAINS "second turn"
OUT {"jsonrpc":"2.0","method":"turn/started","params":{}}
OUT {"jsonrpc":"2.0","method":"item/completed","params":{"item":{"type":"agent_message","id":"msg-recovered","text":"Recovered after abort.","phase":"final_answer"}}}
OUT {"jsonrpc":"2.0","method":"turn/completed","params":{"turn":{"id":"turn-recovered","status":"completed"}}}
EXIT 0
