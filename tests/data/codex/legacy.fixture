# Codex legacy: legacy codex/event notification protocol (older Codex versions)
#
# Sequence:
#   thread/start handshake (same as always)
#   server emits codex/event notifications instead of item/completed

EXPECT_IN_CONTAINS "\"method\":\"initialize\""
OUT {"jsonrpc":"2.0","id":0,"result":{}}
EXPECT_IN_CONTAINS "\"method\":\"initialized\""
EXPECT_IN_CONTAINS "thread/start"
OUT {"jsonrpc":"2.0","id":1,"result":{"threadId":"test-thread-legacy"}}
EXPECT_IN_CONTAINS "turn/start"
OUT {"jsonrpc":"2.0","method":"codex/event","params":{"msg":{"type":"task_started"}}}
OUT {"jsonrpc":"2.0","method":"codex/event","params":{"msg":{"type":"agent_message","message":"Legacy response from Codex."}}}
OUT {"jsonrpc":"2.0","method":"codex/event","params":{"msg":{"type":"exec_command_begin","call_id":"c1","command":"echo hello"}}}
OUT {"jsonrpc":"2.0","method":"codex/event","params":{"msg":{"type":"exec_command_end","call_id":"c1","output":"hello"}}}
OUT {"jsonrpc":"2.0","method":"codex/event","params":{"msg":{"type":"task_complete"}}}
EXIT 0
