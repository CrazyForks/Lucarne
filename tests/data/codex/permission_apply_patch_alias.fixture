# Codex applyPatch alias approval: legacy alias request accepted by client.

EXPECT_IN_CONTAINS "\"method\":\"initialize\""
OUT {"jsonrpc":"2.0","id":0,"result":{}}
EXPECT_IN_CONTAINS "\"method\":\"initialized\""
EXPECT_IN_CONTAINS "thread/start"
OUT {"jsonrpc":"2.0","id":1,"result":{"threadId":"test-thread-perm-apply-alias"}}
EXPECT_IN_CONTAINS "turn/start"
OUT {"jsonrpc":"2.0","id":11,"method":"applyPatchApproval","params":{"file":"/tmp/repo/README.md","reason":"apply patch"}}
EXPECT_IN_CONTAINS "\"decision\":\"accept\""
OUT {"jsonrpc":"2.0","method":"item/completed","params":{"item":{"type":"fileChange","id":"patch-alias-1","status":"completed","changes":[{"path":"/tmp/repo/README.md","kind":"modify","unified_diff":"@@\n-old\n+new\n"}]}}}
OUT {"jsonrpc":"2.0","method":"turn/completed","params":{"turn":{"id":"turn-perm-apply-alias","status":"completed"}}}
EXIT 0
