EXPECT_IN_CONTAINS "\"method\":\"initialize\""
OUT {"jsonrpc":"2.0","id":1,"result":{"protocolVersion":1,"agentCapabilities":{"loadSession":true}}}
EXPECT_IN_CONTAINS "\"method\":\"session/new\""
OUT {"jsonrpc":"2.0","id":2,"result":{"sessionId":"gemini-sess-permission","modes":{"currentModeId":"default","availableModes":[{"id":"default","name":"Default"},{"id":"auto_edit","name":"Auto Edit"},{"id":"yolo","name":"YOLO"},{"id":"plan","name":"Plan"}]},"models":{"currentModelId":"gemini-2.5-flash-lite"}}}
EXPECT_IN_CONTAINS "\"method\":\"session/prompt\""
EXPECT_IN_CONTAINS "Use tools"
OUT {"jsonrpc":"2.0","method":"session/update","params":{"sessionId":"gemini-sess-permission","update":{"sessionUpdate":"tool_call","toolCallId":"tool-1","title":"Read README.md","kind":"read","locations":[{"path":"README.md"}]}}}
OUT {"jsonrpc":"2.0","id":77,"method":"session/request_permission","params":{"sessionId":"gemini-sess-permission","options":[{"optionId":"allow_once","kind":"allow_once","name":"Allow once"},{"optionId":"reject_once","kind":"reject_once","name":"Reject once"}],"toolCall":{"toolCallId":"tool-2","title":"Write live-output.txt","kind":"edit","locations":[{"path":"live-output.txt"}],"content":[{"type":"diff","path":"live-output.txt","oldText":"","newText":"amux-live-tool\n"}]}}}
EXPECT_IN_CONTAINS "\"id\":77"
EXPECT_IN_CONTAINS "\"optionId\":\"allow_once\""
OUT {"jsonrpc":"2.0","method":"session/update","params":{"sessionId":"gemini-sess-permission","update":{"sessionUpdate":"tool_call_update","toolCallId":"tool-2","title":"Write live-output.txt","kind":"edit","status":"completed","rawOutput":"wrote live-output.txt"}}}
OUT {"jsonrpc":"2.0","method":"session/update","params":{"sessionId":"gemini-sess-permission","update":{"sessionUpdate":"agent_message_chunk","messageId":"msg-2","content":{"type":"text","text":"TOOL_OK"}}}}
OUT {"jsonrpc":"2.0","id":3,"result":{"stopReason":"end_turn","usage":{"inputTokens":7,"outputTokens":4,"cachedReadTokens":1,"totalTokens":12}}}
EXIT 0
