# Grok ACP resume: session/load then dense isReplay history (production failure mode).
# Live channel bus is only 256 slots; replaying thousands of history updates
# as TimelineEvents causes lag/SIGKILL. Dialect must drop isReplay + emit only
# the live prompt turn.
EXPECT_IN_CONTAINS "initialize"
OUT {"jsonrpc":"2.0","id":1,"result":{"protocolVersion":1,"agentCapabilities":{"loadSession":true}}}
EXPECT_IN_CONTAINS "session/load"
OUT {"jsonrpc":"2.0","id":2,"result":{"sessionId":"uuid-resume-flood"}}
OUT {"jsonrpc":"2.0","method":"session/update","params":{"sessionId":"uuid-resume-flood","update":{"sessionUpdate":"user_message_chunk","content":{"type":"text","text":"replay-user-0"}},"_meta":{"isReplay":true}}}
