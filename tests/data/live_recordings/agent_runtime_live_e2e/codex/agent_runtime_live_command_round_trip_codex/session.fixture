-privacy-policy/","termsOfServiceUrl":"https://openai.com/policies/row-terms-of-use/","defaultPrompt":["Use relevant skills and databases to support life-science research tasks."],"brandColor":"#166534","composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/life-science-research/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/life-science-research/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"expo@openai-curated","name":"expo","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/expo"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Expo","shortDescription":"Build, deploy, upgrade, and debug Expo and React Native apps","longDescription":"Official Expo-authored skills for building Expo Router UI, authoring API routes, configuring data fetching and styling, writing Expo native modules, creating dev clients, upgrading Expo SDKs, wiring Codex app Run actions, and deploying Expo apps with EAS workflows, builds, hosting, TestFlight, App Store, and Play Store guidance.","developerName":"Expo","category":"Coding","capabilities":["Interactive","Read","Write"],"websiteUrl":"https://expo.dev/","privacyPolicyUrl":"https://expo.dev/privacy","termsOfServiceUrl":"https://expo.dev/terms","defaultPrompt":["Use Expo when building, deploying, upgrading, debugging, or wiring Codex app Run actions for Expo and React Native apps."],"brandColor":"#000020","composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/expo/assets/expo.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/expo/assets/expo.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"coderabbit@openai-curated","name":"coderabbit","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/