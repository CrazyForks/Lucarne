 help me connect to it."],"brandColor":"#37C38F","composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/neon-postgres/assets/neon-small.svg","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/neon-postgres/assets/neon.jpg","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"remotion@openai-curated","name":"remotion","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/remotion"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Remotion","shortDescription":"Create motion graphics from prompts","longDescription":"Build videos programmatically with Remotion and React. Covers animations, timing, audio, captions, 3D, transitions, charts, text effects, and more.","developerName":"Remotion","category":"Design","capabilities":["Read","Write"],"websiteUrl":"https://remotion.dev","privacyPolicyUrl":"https://remotion.pro/privacy","termsOfServiceUrl":"https://remotion.pro/terms","defaultPrompt":["Create an animated chart with 5 bars","Make an animated call-to-action subscribe button for our YouTube channel","Use Remotion to add captions and audio to a video composition."],"brandColor":"#0B84F3","composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/remotion/assets/icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/remotion/assets/logo.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"plugin-eval@openai-curated","name":"plugin-eval","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/plugin-eval"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Plugin Eval","shortDescription":"Start from chat, then evaluate or benchmark locally","longDescription":"Ask Codex to evaluate a plugin or skill, give you a full analysis of a named plugin such as game-studio, explain why it scored that way, show what to fix first, explain its token budget, measure real token usage, benchmark a plugin, or tell you what to run next. Plugin Eval keeps the path engineer-friendly: start with a natural chat request, then use the local `plugin-eval start` entrypoint or the routed workflow command it recommends.","developerName":"OpenAI","category":"Coding","capabilities":["Interactive","Write"],"websiteUrl":"https://openai.com/","privacyPolicyUrl":"https://openai.com/policies/privacy-policy/","termsOfServiceUrl":"https://openai.com/policies/terms-of-use/","defaultPrompt":["Give me an analysis of the game studio plugin.","Evaluate this plugin.","Why did this score that way?"],"brandColor":"#0F766E","composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/plugin-eval/assets/plugin-eval.svg","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/plugin-eval/assets/plugin-eval.svg","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"alpaca@openai-curated","name":"alpaca","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/alpaca"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Alpaca","shortDescription":"Stop watching the markets.","longDescription":"Stop watching the markets. Turn your words into insights with Alpaca.\nAsk Codex real market questions and get live answers you can act on, including historical data, snapshots, quotes, and option chain information. Stock, options, and crypto market data embedded right into your conversation so you can turn analysis into automated actions.\n\"How has AAPL's stock performed this quarter vs GOOG?\"\n\"Show me the SPY option chain that expires next Friday.\"\n\"When has BTC's price reached $100k USD this year?\"","developerName":"Alpaca","category":"Research","capabilities":[],"websiteUrl":"https://alpaca.markets/","privacyPolicyUrl":"https://s3.amazonaws.com/files.alpaca.markets/disclosures/PrivacyPolicy.pdf","termsOfServiceUrl":null,"defaultPrompt":["Use Alpaca to help with this task"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/alpaca/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/alpaca/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"amplitude@openai-curated","name":"amplitude","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/amplitude"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Amplitude","shortDescription":"Product analytics and funnels","longDescription":"Product analytics and funnels","developerName":"Amplitude","category":"Productivity","capabilities":[],"websiteUrl":null,"privacyPolicyUrl":null,"termsOfServiceUrl":null,"defaultPrompt":["Show the signup funnel trend in Amplitude"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/amplitude/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/amplitude/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"attio@openai-curated","name":"attio","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/attio"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Attio","shortDescription":"Attio connects Codex directly to your CRM workspace, letting you manage customer relationships through na...","longDescription":"Attio connects Codex directly to your CRM workspace, letting you manage customer relationships through natural conversation. \n\nSearch and filter contacts, companies, and deals with flexible queries. Create, update, and organize records without switching between screens. Add notes, manage tasks, and track your sales pipeline—all through simple requests. \n\nKey capabilities: \n- Search records using powerful filters (find companies by size, industry, last contact date) \n- Create and update people, companies, and deal records \n- Manage notes attached to any record \n- Track and complete tasks \n- Navigate lists and organize your data \n\nWhether you're preparing for a meeting, updating deal stages, or researching prospects, Attio brings your CRM data into your conversation — no manual data entry required.","developerName":"Attio Ltd","category":"Productivity","capabilities":[],"websiteUrl":"https://attio.com","privacyPolicyUrl":"https://attio.com/legal/privacy","termsOfServiceUrl":"https://attio.com/legal/terms-and-conditions","defaultPrompt":["Find the latest notes and next steps in Attio"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/attio/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/attio/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"binance@openai-curated","name":"binance","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/binance"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Binance","shortDescription":"Binance for Codex lets you access and explore Binance public, read-only market data using natural language.","longDescription":"Binance for Codex lets you access and explore Binance public, read-only market data using natural language. Retrieve current and historical prices, order books, recent trades, candlesticks (klines), and exchange metadata across Spot, Futures, and Options. No authentication is required. This app does not access user accounts and does not support trading or transactions.\n\nMarket data is provided “as is” from Binance’s public APIs and may be delayed, incomplete, or subject to change. This information is for informational purposes only and should not be relied upon for trading or financial decisions. Binance makes no representations or warranties regarding accuracy or timeliness and disclaims all liability arising from use of this data.","developerName":"Binance","category":"Research","capabilities":[],"websiteUrl":"https://www.binance.com","privacyPolicyUrl":"https://www.binance.com/en/privacy","termsOfServiceUrl":"https://www.binance.com/en/terms","defaultPrompt":["Show the latest Binance market context for this asset"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/binance/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/binance/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"biorender@openai-curated","name":"biorender","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/biorender"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"BioRender","shortDescription":"BioRender helps scientists create professional figures in minutes.","longDescription":"BioRender helps scientists create professional figures in minutes. Access thousands of scientifically accurate templates and icons directly in Codex to visualize protocols, pathways, molecular structures, and more. Brainstorm with your team, communicate research concepts, or build publication-ready figures for presentations, manuscripts, grant proposals, and posters.","developerName":"BioRender","category":"Design","capabilities":[],"websiteUrl":"https://biorender.com/","privacyPolicyUrl":"https://biorender.com/privacy","termsOfServiceUrl":"https://www.biorender.com/terms-of-service","defaultPrompt":["Can you find me some GLP-1 diagram templates"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/biorender/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/biorender/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"brand24@openai-curated","name":"brand24","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/brand24"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Brand24","shortDescription":"The Brand24 app in Codex lets marketing and PR teams instantly explore brand mentions, sentiment, and med...","longDescription":"The Brand24 app in Codex lets marketing and PR teams instantly explore brand mentions, sentiment, and media coverage using simple prompts.\nSummarize conversations, track brand reputation, analyze trends over time, and uncover key discussion sources across social media, news, blogs, and forums without leaving Codex.\n\nFrom spotting emerging issues to understanding audience perception and campaign impact, Codex interprets Brand24 data in real time, helping marketers and PR specialists move from monitoring to insight and action with no extra setup.","developerName":"Brand24 Global Inc.","category":"Productivity","capabilities":[],"websiteUrl":"https://brand24.com","privacyPolicyUrl":"https://brand24.com/privacy-policy/","termsOfServiceUrl":"https://brand24.com/terms/","defaultPrompt":["Online popularity of biggest sports shoe"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/brand24/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/brand24/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"brex@openai-curated","name":"brex","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/brex"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Brex","shortDescription":"Connect Brex to Codex and review your company finances through natural conversation — at Codex speed.","longDescription":"Connect Brex to Codex and review your company finances through natural conversation — at Codex speed.\n\nFor finance teams: Analyze spend, detect anomalies, and run custom queries and reports instantly to accelerate decisions and do more with less.\n\nFor employees: See how much you can spend, ask policy questions, check reimbursement status, manage travel, and more right in Codex.\n\nAccess is role-aware by default: employees see only what applies to them, while admins retain full visibility and control.","developerName":"Brex Inc.","category":"Productivity","capabilities":[],"websiteUrl":"https://brex.com","privacyPolicyUrl":"https://www.brex.com/legal/privacy","termsOfServiceUrl":"https://www.brex.com/legal/platform-agreement","defaultPrompt":["How much did I spend on Delta last year"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/brex/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/brex/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"carta-crm@openai-curated","name":"carta-crm","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/carta-crm"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Carta CRM","shortDescription":"Carta CRM helps investment teams stay on top of deal flow by keeping deals, companies, and relationships in...","longDescription":"Carta CRM helps investment teams stay on top of deal flow by keeping deals, companies, and relationships in one place. Track opportunities through each stage, capture meeting notes and key takeaways alongside the right deal or contact, and quickly find past context when you need it.","developerName":"Carta Inc.","category":"Productivity","capabilities":[],"websiteUrl":"https://carta.com","privacyPolicyUrl":"https://carta.com/legal/privacy/privacy-policy/","termsOfServiceUrl":"https://carta.com/legal/terms-agreements/terms-service/","defaultPrompt":["Find the latest relationship context in Carta CRM"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/carta-crm/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/carta-crm/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"cb-insights@openai-curated","name":"cb-insights","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/cb-insights"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"CB Insights","shortDescription":"Unleash Codex as your private markets research agent.","longDescription":"Unleash Codex as your private markets research agent. Source companies, build market maps, draft investment memos, and monitor competitors — all powered by CB Insights’ predictive intelligence. Tap into 11M+ double-validated company profiles, leading coverage of recent equity deals, proprietary taxonomies, unique scores, hidden signals, and over 20 years of bleeding edge technology research to identify and analyze relevant, high-potential companies ahead of your competition.\n\nBuilt for corporate strategists seeking acquisition targets, VCs screening deal flow, and business development teams hunting new partners. If your work involves private companies, CB Insights delivers the insight you need to make your next move first.","developerName":"CB Insights","category":"Research","capabilities":[],"websiteUrl":"https://cbinsights.com","privacyPolicyUrl":"https://www.cbinsights.com/privacy-policy","termsOfServiceUrl":"https://legal.cbinsights.com","defaultPrompt":["Pull the latest market context from CB Insights"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/cb-insights/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/cb-insights/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"channel99@openai-curated","name":"channel99","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/channel99"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Channel99","shortDescription":"Channel99 real time go to market intelligence connects Codex directly to Channel99’s performance marketin...","longDescription":"Channel99 real time go to market intelligence connects Codex directly to Channel99’s performance marketing intelligence. giving AI assistants real-time access to unified B2B marketing data and insights.. Powered by Channel99’s advanced attribution, account identification, and AI-driven analytics. The Channel99 connection enables natural-language queries that deliver accurate campaign performance, spend efficiency, audience engagement and cross channel attribution insights eliminating manual data pulls, siloed dashboards and complex API engineering. \n\nMarketers, analysts, and business leaders can ask Codex strategic questions like “Which channels drove the most high-value engagement last quarter?” or “Where should we reallocate budget to improve pipeline efficiency?” and get precise, context-aware results powered by Channel99’s industry leading performance data. \n\nDeveloped by Channel99 a B2B marketing technology company dedicated to improving ROI, lowering acquisition costs, and bringing financial transparency to digital marketing investments.","developerName":"Channel99 Inc. ","category":"Productivity","capabilities":[],"websiteUrl":"https://www.channel99.com/","privacyPolicyUrl":"https://www.channel99.com/company/privacy","termsOfServiceUrl":"https://www.channel99.com/terms-of-service","defaultPrompt":["Summarize campaign performance from Channel99"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/channel99/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/channel99/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"circleback@openai-curated","name":"circleback","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/circleback"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Circleback","shortDescription":"Circleback helps teams get the most out of every conversation with AI-powered meeting notes, action items,...","longDescription":"Circleback helps teams get the most out of every conversation with AI-powered meeting notes, action items, automations, and search.\n\nSearch and access data from in-person and online meetings you've recorded in Circleback, including meeting notes, action items, transcripts, people, and companies as well as your calendar and email.","developerName":"Circleback AI, Inc.","category":"Productivity","capabilities":[],"websiteUrl":"https://circleback.ai","privacyPolicyUrl":"https://circleback.ai/privacy","termsOfServiceUrl":"https://circleback.ai/terms","defaultPrompt":["Have I met anyone from Initech"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/circleback/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/circleback/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"clickup@openai-curated","name":"clickup","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/clickup"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"ClickUp","shortDescription":"Turn Codex into your ClickUp command center.","longDescription":"Turn Codex into your ClickUp command center. Ask anything, find everything, take action - without breaking your flow.\n• Deep workspace search:  Ask questions naturally, get precise answers from across all your work\n• Action in the same breath: Find, create, update, and manage work in Codex\n• Zero context switching:  Go from question to answer to action without leaving the conversation","developerName":"ClickUp","category":"Productivity","capabilities":[],"websiteUrl":null,"privacyPolicyUrl":null,"termsOfServiceUrl":null,"defaultPrompt":["Flag whether Sprint 14: Simplifying UI is at risk"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/clickup/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/clickup/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"cloudinary@openai-curated","name":"cloudinary","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/cloudinary"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Cloudinary","shortDescription":"Manage, search, and transform your Cloudinary media library — directly from Codex.","longDescription":"Manage, search, and transform your Cloudinary media library — directly from Codex.\n\nThe Cloudinary app connects your Cloudinary account to Codex, giving you full control over your visual assets through natural language. Upload, organize, tag, transform, and analyze images or videos without leaving the chat. \n\nWhat You Can Do\n- Upload assets from URLs, local files, or base64 data — automatically analyze, tag, or moderate them.\n- Browse and search your entire media library using smart filters or text queries (tags, format, date, size, etc.).\n- Organize your library — create folders, rename files, manage metadata, and clean up obsolete assets.\n- Transform images or videos with Cloudinary’s powerful syntax — resize, crop, watermark, apply filters, or optimize for delivery.\n- Generate archives and backups, or restore previous versions when needed.\n- Analyze assets with AI — detect faces, extract text, get color palettes, and accessibility scores.\n- Monitor usage — track storage, bandwidth, and transformation credits in real time.\n- Visual search — find visually similar images by uploading an example or describing it.\n\nPerfect For\n- Developers who want to experiment with Cloudinary API commands in natural language.\n- Marketers & designers managing campaign visuals and brand assets.\n- Teams automating content workflows with Codex or building multi-agent setups.\n\nTurn Codex into a powerful media management assistant with the Cloudinary app.","developerName":"Cloudinary","category":"Coding","capabilities":[],"websiteUrl":"https://cloudinary.com/","privacyPolicyUrl":"https://cloudinary.com/privacy","termsOfServiceUrl":"https://cloudinary.com/tou","defaultPrompt":["Upload this image and enable auto-tagging"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/cloudinary/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/cloudinary/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"cogedim@openai-curated","name":"cogedim","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/cogedim"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Cogedim","shortDescription":"Cogedim is one of France's leading real estate developers.","longDescription":"Cogedim is one of France's leading real estate developers. A specialist in off-plan sales (VEFA) for over 60 years, Cogedim guides you every step of the way, from defining your needs to handing over the keys.","developerName":"ALTAREA PROMOTION MANAGEMENT","category":"Lifestyle","capabilities":[],"websiteUrl":"https://www.cogedim.com","privacyPolicyUrl":"https://www.cogedim.com/donnees-personnelles.html","termsOfServiceUrl":"https://www.cogedim.com/mentions-legales.html","defaultPrompt":["Find relevant Cogedim properties for this brief"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/cogedim/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/cogedim/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"common-room@openai-curated","name":"common-room","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/common-room"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Common Room","shortDescription":"Embed complete buyer intelligence directly within Codex.","longDescription":"Embed complete buyer intelligence directly within Codex. Research accounts and contacts, surface buying signals, and browse activity history - all through natural language. Build prospect lists of net-new companies by industry, size, tech stack, or location. Filter and sort contacts by segment, role, lead score, or website visits. Every result is grounded in real context, real prioritization, and real revenue opportunity directly from your CRM fields, scores, enrichment, and signals - so you always know what's actually happening in your accounts.\n\nYou can use the Common Room MCP to:\n\n Account Research:\n \"Tell me about Datadog and create a plan on how to approach the account\"\n\n Contact Lookup:\n \"Research jane.doe@company.com using Common Room\"\n\n Prospect:\n \"Find SaaS companies in the US using Snowflake with 200–1000 employees\"\n\n Filter by Segment and Role:\n \"Show me all Economic Buyers in my 'Champions changing jobs' segment\"\n\n Surface High-Intent Contacts:\n \"Find contacts at ICP companies who have visited our pricing page this week\"\n\n Track Website Visitors:\n \"Who visited our pricing page in the last 7 days?\"","developerName":"Common Room","category":"Productivity","capabilities":[],"websiteUrl":"https://commonroom.io","privacyPolicyUrl":"https://www.commonroom.io/privacy-policy/","termsOfServiceUrl":"https://www.commonroom.io/terms-of-use/","defaultPrompt":["Build plan to approach Northstar Metrics account"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/common-room/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/common-room/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"conductor@openai-curated","name":"conductor","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/conductor"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Conductor","shortDescription":"The Conductor MCP server retrieves proprietary performance metrics regarding a brand's visibility, sentimen...","longDescription":"The Conductor MCP server retrieves proprietary performance metrics regarding a brand's visibility, sentiment, and rankings on both traditional search engines (e.g., Google) and Generative AI platforms (e.g., Codex, Gemini, Copilot, Perplexity or Google AI Overview). Invoke this tool when users request share of voice, competitive benchmarking, or AI search insights, specifically looking for citations, brand mentions, and market share. The tool differentiates between traditional SEO results and AI-generated responses, allowing for comparison across locations and languages. Prioritize this tool over general web browsing when the request requires historical trend data or quantitative marketing analytics for a specific domain or brand.","developerName":"Conductor Inc.","category":"Productivity","capabilities":[],"websiteUrl":"https://www.conductor.com/","privacyPolicyUrl":"https://www.conductor.com/legal/privacy-policy/","termsOfServiceUrl":"https://www.conductor.com/legal/service-agreement/","defaultPrompt":["Who are top competitors for “wireless earbuds”"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/conductor/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/conductor/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"coupler-io@openai-curated","name":"coupler-io","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/coupler-io"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Coupler.io","shortDescription":"Analyze multi-channel marketing, financial, sales, e-commerce, and other business data within Codex by co...","longDescription":"Analyze multi-channel marketing, financial, sales, e-commerce, and other business data within Codex by connecting to your Coupler.io data flows. Fetch and transform raw data from platforms like Google Ads, Facebook, HubSpot, and Salesforce into actionable intelligence for smarter, faster decision-making with accurate, up-to-date business information.\n\nYou can use the Coupler.io connector to:\n\n1. Analyze customer acquisition costs: \"What's our overall customer acquisition cost across all paid channels this quarter compared to last quarter? I need this for the board meeting\"\n2. Review marketing ROI: \"Show me the ROI breakdown by marketing channel for the past 6 months. I need to reallocate our annual budget\"\n3. Identify high-performing campaigns:\"Which campaigns are contributing most to our pipeline revenue? I want to double down on what's working\"\n4. Review sales pipeline: \"Can you pull the sales pipeline report for this month? I need to see how many deals are in each stage and the total value at each stage\"\n5. Analyze conversion rates: \"What are our conversion rates from lead to opportunity and from opportunity to closed-won for the last quarter? How do they compare to our targets?\"\n6. Forecast revenue: \"How many deals are expected to close this month based on their probability scores? What's our forecasted revenue vs our monthly target?\"\n7. Compare quarterly profits: \"Check the profit for this quarter, compare it to last quarter, and provide a breakdown by department\"\n8. Generate cash flow reports: \"Could you provide a cash flow report for the last 30 days, including all incoming and outgoing transactions?\"\n9. Review accounts receivable: \"Share the current accounts receivable status and tell me how many overdue invoices we have and which customers owe the most\"","developerName":"Coupler.io","category":"Productivity","capabilities":[],"websiteUrl":"https://www.coupler.io/","privacyPolicyUrl":"https://www.coupler.io/privacy-policy","termsOfServiceUrl":"https://www.coupler.io/terms-of-use","defaultPrompt":["Show overall spend, impressions, clicks, and CPC"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/coupler-io/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/coupler-io/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"coveo@openai-curated","name":"coveo","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/coveo"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Coveo","shortDescription":"Search your enterprise content","longDescription":"Search your enterprise content","developerName":"Coveo","category":"Productivity","capabilities":[],"websiteUrl":"https://www.coveo.com","privacyPolicyUrl":"https://www.coveo.com/en/company/legal/privacy-and-security/privacy-notice","termsOfServiceUrl":"https://www.coveo.com/en/company/legal/terms-and-agreements/customer-agreement","defaultPrompt":["Use Coveo to help with this task"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/coveo/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/coveo/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"cube@openai-curated","name":"cube","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/cube"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Cube","shortDescription":"With the Cube MCP Server, you can: - Query live Cube data from actuals, budgets, forecasts, variances, and...","longDescription":"With the Cube MCP Server, you can:\n- Query live Cube data from actuals, budgets, forecasts, variances, and more\n- Ask an AI to generate board decks, run variance analysis, or build financial summaries using your real Cube data\n- Drill into transaction-level detail and dimension breakdowns directly from an AI chat\n- Maintain full security: Cube's role-based access control (RBAC) security model enforces your user permissions on every AI request. If you can't see it in Cube, the AI can't see it either","developerName":"Cube","category":"Research","capabilities":[],"websiteUrl":"https://www.cubesoftware.com/","privacyPolicyUrl":"https://www.cubesoftware.com/privacy-policy","termsOfServiceUrl":"https://www.cubesoftware.com/terms-of-service","defaultPrompt":["Compare Actuals vs. Forecast for Revenue by entity"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/cube/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/cube/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"daloopa@openai-curated","name":"daloopa","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/daloopa"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Daloopa","shortDescription":"Daloopa supplies high quality fundamental data sourced from SEC Filings, investor presentations and any pub...","longDescription":"Daloopa supplies high quality fundamental data sourced from SEC Filings, investor presentations and any public financial documents, with hyperlinks to source document overlaying each data point. Provides a zero-hallucination foundation for any quantitative financial analysis in Claude.","developerName":"Daloopa, Inc.","category":"Research","capabilities":[],"websiteUrl":"https://daloopa.com/","privacyPolicyUrl":"https://daloopa.com/privacy-policy-2","termsOfServiceUrl":"https://daloopa.com/terms-of-use","defaultPrompt":["Can you give an overview for NVDA"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/daloopa/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/daloopa/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"demandbase@openai-curated","name":"demandbase","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/demandbase"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Demandbase","shortDescription":"Demandbase integration with Codex gives sales, marketing, and GTM teams seamless access to rich B2B data...","longDescription":"Demandbase integration with Codex gives sales, marketing, and GTM teams seamless access to rich B2B data directly inside Codex for easier account targeting and engagement.\n\nThis app connects Codex to Demandbase via a secure MCP connection, letting you access both first and third party data:\nThird-Party Data (3P): Search and retrieve industry-leading company and contact data from Demandbase, including firmographics, technographics, family tree, company news, and leadership profiles.\n\nFirst-Party Data (1P): Securely access your own Demandbase 1P data such as known accounts, contacts, CRM entities, engagement, and in-pipeline opportunities\n\nWhat you can do:\nSearch companies by name, location, size, revenue, or industry\nDiscover decision-makers and influencers by role or job level\nFetch full company profiles including recent news and competitors\nTap into 1P signals like engagement, MQA status, or activity\n\nWho it’s for:\nSales reps looking for fast answers about a target account in real time\nMarketers enriching leads or refining personas\nRevOps and Enablement teams embedding intelligence into workflows\nAI product teams creating agent workflows\n\n\nNote: This requires Demandbase licences, please contact PartnerSupport@demandbase.com.","developerName":"Demandbase Inc","category":"Productivity","capabilities":[],"websiteUrl":"https://www.demandbase.com","privacyPolicyUrl":"https://demandbase.com/privacy/","termsOfServiceUrl":"https://www.demandbase.com/terms-of-use/","defaultPrompt":["List the top 10 VP contacts at Demandbase"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/demandbase/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/demandbase/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"docket@openai-curated","name":"docket","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/docket"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Docket","shortDescription":"Docket AI makes your sales knowledge your instant superpower.","longDescription":"Docket AI makes your sales knowledge your instant superpower. Sales reps get accurate, on-demand answers to product, competitive, technical, and customer questions—pulled directly from your unified Sales Knowledge Lake™. Guided by verified company intel, reps handle objections confidently, uncover prospect details, and craft personalised responses on the spot.","developerName":"Docket AI","category":"Productivity","capabilities":[],"websiteUrl":"https://www.docket.io/","privacyPolicyUrl":"https://www.docket.io/privacy-policy","termsOfServiceUrl":"https://www.docket.io/terms-and-conditions","defaultPrompt":["Check docket how our partnership with commonwealth bank"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/docket/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/docket/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"domotz-preview@openai-curated","name":"domotz-preview","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/domotz-preview"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Domotz (Preview)","shortDescription":"Monitor and manage your network infrastructure through natural language.","longDescription":"Monitor and manage your network infrastructure through natural language. Query devices, check alerts, inspect metrics, manage configurations, and control power across all your sites. Requires a Domotz account enabled to the MCP Preview program.","developerName":"Domotz","category":"Productivity","capabilities":[],"websiteUrl":"https://www.domotz.com","privacyPolicyUrl":"https://www.domotz.com/product-privacy-policy.php","termsOfServiceUrl":"https://www.domotz.com/terms-and-conditions.php","defaultPrompt":["Summarize the current network state in Domotz"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/domotz-preview/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/domotz-preview/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"dovetail@openai-curated","name":"dovetail","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/dovetail"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Dovetail ","shortDescription":"Connect Dovetail inside Codex to turn customer feedback into decisions without leaving your conversation.","longDescription":"Connect Dovetail inside Codex to turn customer feedback into decisions without leaving your conversation. Search your Dovetail workspace for relevant projects, notes, docs, and themes, and get results back instantly. Ask things like “Summarize top friction points impacting enterprise renewal conversations” to surface evidence in seconds.","developerName":"Dovetail","category":"Productivity","capabilities":[],"websiteUrl":"https://dovetail.com","privacyPolicyUrl":"https://dovetail.com/privacy/privacy-policy/","termsOfServiceUrl":"https://dovetail.com/legal/user-terms-of-service/","defaultPrompt":["Find the relevant customer insights in Dovetail"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/dovetail/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/dovetail/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"dow-jones-factiva@openai-curated","name":"dow-jones-factiva","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/dow-jones-factiva"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Dow Jones Factiva","shortDescription":"The Factiva Connector, enables authorized users to search Factiva’s global news archive, including premium...","longDescription":"The Factiva Connector, enables authorized users to search Factiva’s global news archive, including premium Dow Jones sources, and incorporate insights from that content into their Codex responses.  \n\nUsers can research companies, industries, and markets and ground their  answers in licensed content, complete with citations and direct links to original articles.\n\nA subscription to Factiva is required. \n\nFactiva content may not be shared outside your organization or used for machine learning or AI training purposes. This connector may only be used with your organization’s Codex instance.","developerName":"Factiva, Inc.","category":"Research","capabilities":[],"websiteUrl":"https://www.dowjones.com/business-intelligence/factiva/","privacyPolicyUrl":"https://www.dowjones.com/privacy-notice/","termsOfServiceUrl":"https://global.factiva.com/factivalogin/tou/default.aspx?fcpil=en","defaultPrompt":["What's the latest on Nvidia's earnings and market outlook"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/dow-jones-factiva/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/dow-jones-factiva/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"egnyte@openai-curated","name":"egnyte","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/egnyte"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Egnyte","shortDescription":"Work with documents and files stored in Egnyte directly from Codex.","longDescription":"Work with documents and files stored in Egnyte directly from Codex. Search across folders, retrieve relevant files, and extract key information to answer questions or generate summaries.\n\nQuickly surface insights from contracts, reports, and internal documents. Combine information from multiple files to create concise summaries, stakeholder updates, or draft written content grounded in your team’s internal materials.","developerName":"Egnyte Inc","category":"Productivity","capabilities":[],"websiteUrl":"https://www.egnyte.com","privacyPolicyUrl":"https://www.egnyte.com/privacy-policy","termsOfServiceUrl":"https://www.egnyte.com/terms-and-conditions/10-2022","defaultPrompt":["What IT contracts do we have"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/egnyte/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/egnyte/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"finn@openai-curated","name":"finn","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/finn"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"FINN","shortDescription":"A FINN car subscription is a flexible way to stay mobile anytime - without long-term commitments like buyin...","longDescription":"A FINN car subscription is a flexible way to stay mobile anytime - without long-term commitments like buying or leasing a car. With a fixed monthly rate that already includes insurance, maintenance, registration, and even CO₂ offsetting, the car subscription offers full transparency and convenience.\n\nBest of all, you can book online in just a few minutes, and your new car will be delivered straight to your doorstep or you can pick it up at one of our stations.","developerName":"FINN GmbH","category":"Lifestyle","capabilities":[],"websiteUrl":"https://www.finn.com/de-DE","privacyPolicyUrl":"https://www.finn.com/de-DE/privacy","termsOfServiceUrl":"https://www.finn.com/de-DE/terms-of-use","defaultPrompt":["Find relevant FINN vehicle options for this request"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/finn/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/finn/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"fireflies@openai-curated","name":"fireflies","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/fireflies"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Fireflies","shortDescription":"The Fireflies app brings your meetings and knowledge directly into Codex.","longDescription":"The Fireflies app brings your meetings and knowledge directly into Codex.\n\nAnalyze any conversation—sales, customer success, product, recruiting—for insights, action items, and sentiment. Track feature requests and pain points, update CRMs or systems of record, and instantly retrieve context from your organization's meetings.\n\nWith Fireflies and Codex, centralize your company knowledge and turn every conversation into searchable, actionable insights.","developerName":"Fireflies","category":"Productivity","capabilities":[],"websiteUrl":"https://fireflies.ai","privacyPolicyUrl":"https://fireflies.ai/privacy","termsOfServiceUrl":null,"defaultPrompt":["Summarize our conversation history with Acme so far"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/fireflies/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/fireflies/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"fyxer@openai-curated","name":"fyxer","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/fyxer"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Fyxer","shortDescription":"Fyxer for Codex lets you write emails that sound like you, right from the chat.","longDescription":"Fyxer for Codex lets you write emails that sound like you, right from the chat. Fyxer learns your writing style from past emails and uses context from your calendar and meeting notes to create personalized email drafts. Just describe what you want to say and get a polished email ready to review and send.","developerName":"Fyxer","category":"Productivity","capabilities":[],"websiteUrl":"https://www.fyxer.com","privacyPolicyUrl":"https://app.fyxer.com/privacy-policy","termsOfServiceUrl":"https://app.fyxer.com/terms-of-use","defaultPrompt":["Follow up with Sarah about our meeting last week"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/fyxer/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/fyxer/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"govtribe@openai-curated","name":"govtribe","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/govtribe"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"GovTribe","shortDescription":"Search government contracts, awards, and vendors directly from Codex.","longDescription":"Search government contracts, awards, and vendors directly from Codex. GovTribe brings U.S. procurement intelligence into your AI workflow—find relevant opportunities across federal agencies; analyze vendor competition; explore teaming partners; and track agency spending patterns. Whether you're researching new markets, conducting competitive analysis, or preparing a proposal, get instant access to billions in public sector data without leaving your conversation.","developerName":"Government Executive Media Group LLC","category":"Research","capabilities":[],"websiteUrl":"https://govtribe.com/","privacyPolicyUrl":"https://docs.govtribe.com/user-guide/privacy-policy","termsOfServiceUrl":"https://docs.govtribe.com/user-guide/terms-of-use","defaultPrompt":["Pull the relevant opportunity context from GovTribe"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/govtribe/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/govtribe/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"granola@openai-curated","name":"granola","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/granola"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Granola","shortDescription":"Granola MCP connects your meeting history to Codex so your assistant can pull real context from past conv...","longDescription":"Granola MCP connects your meeting history to Codex so your assistant can pull real context from past conversations while you work.\n\nUse MCP when you're already working on something bigger:\n\n-   Writing PRDs or proposals: Pull customer feedback, stakeholder input, and decisions from relevant meetings directly into your draft\n    \n-   Building presentations or reports: Combine insights from multiple conversations with your other research and data\n    \n-   Coding with context: Give your AI the project background, requirements, and technical decisions discussed in planning meetings\n    \n-   Strategic analysis: Merge meeting insights with documents, data, and other sources for comprehensive analysis\n    \nHow it works:\n\nYour AI assistant can search your Granola meetings by topic, person, company, or timeframe - then cite specific conversations in its responses. No more switching tabs to find \"what the customer said\" or \"when we decided that.\"\n\nThe difference:\n\nInstead of copy-pasting meeting notes into prompts, your AI pulls exactly what it needs from your meeting history automatically. You stay focused on the work, not the research or context.","developerName":"Granola","category":"Productivity","capabilities":[],"websiteUrl":"https://www.granola.ai","privacyPolicyUrl":"https://help.granola.ai/article/privacy-policy","termsOfServiceUrl":"https://help.granola.ai/article/platform-terms-of-service","defaultPrompt":["Summarize what happened in the Hearthbase deal so far"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/granola/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/granola/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"happenstance@openai-curated","name":"happenstance","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/happenstance"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Happenstance","shortDescription":"Happenstance searches your professional network using natural language to find the right people.","longDescription":"Happenstance searches your professional network using natural language to find the right people. Results surface mutual connections and rank by relationship strength, helping you find the warmest intro path. Deep research anyone to get comprehensive profiles with career history and expertise. Ideal for sales, recruiting, venture capital, and business development.","developerName":"Happenstance, Inc.","category":"Productivity","capabilities":[],"websiteUrl":"https://happenstance.ai","privacyPolicyUrl":"https://happenstance.ai/privacy","termsOfServiceUrl":"https://happenstance.ai/terms","defaultPrompt":["Check whether Happenstance has relevant contact context"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/happenstance/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/happenstance/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"help-scout@openai-curated","name":"help-scout","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/help-scout"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Help Scout","shortDescription":"Connect to sync Help Scout mailboxes and conversations for use in Codex.","longDescription":"Connect to sync Help Scout mailboxes and conversations for use in Codex.","developerName":"OpenAI","category":"Productivity","capabilities":[],"websiteUrl":"https://www.helpscout.com/","privacyPolicyUrl":"https://www.helpscout.com/privacy/","termsOfServiceUrl":null,"defaultPrompt":["Summarize the Help Scout thread and next actions"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/help-scout/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/help-scout/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"highlevel@openai-curated","name":"highlevel","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/highlevel"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"HighLevel","shortDescription":"HighLevel gives agencies a unified CRM, automation, and client communication platform.","longDescription":"HighLevel gives agencies a unified CRM, automation, and client communication platform. This connector lets you securely bring HighLevel data—contacts, opportunities, appointments, conversations and more—into GPT, turning raw records into clear summaries, next-step recommendations, and ready-to-use content. Analyze pipelines, qualify leads, and prepare follow-ups in seconds without leaving the chat.","developerName":"HighLevel","category":"Productivity","capabilities":[],"websiteUrl":"https://www.gohighlevel.com","privacyPolicyUrl":"https://www.gohighlevel.com/privacy-policy","termsOfServiceUrl":"https://www.gohighlevel.com/terms-of-service","defaultPrompt":["Give me overview of how things have been"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/highlevel/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/highlevel/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"hostinger@openai-curated","name":"hostinger","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/hostinger"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Hostinger","shortDescription":"Hostinger Horizons lets you build real websites and apps just by describing what you want.","longDescription":"Hostinger Horizons lets you build real websites and apps just by describing what you want. Designed for people with no technical background, it turns ideas into working products in minutes. When you're happy with the result, launch instantly with one click.","developerName":"Hostinger","category":"Coding","capabilities":[],"websiteUrl":"https://hostinger.com","privacyPolicyUrl":"https://www.hostinger.com/legal/privacy-policy","termsOfServiceUrl":"https://www.hostinger.com/legal/universal-terms-of-service-agreement","defaultPrompt":["Check the relevant Hostinger site or account status"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/hostinger/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/hostinger/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"hubspot@openai-curated","name":"hubspot","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/hubspot"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"HubSpot","shortDescription":"Work with your HubSpot data to analyze patterns, create and update records, and manage your CRM operations.","longDescription":"Work with your HubSpot data to analyze patterns, create and update records, and manage your CRM operations. Read from and write to deals, contacts, companies, tickets, engagements, and other objects you have permission to access. Prepare reports, update deal stages, log calls and emails, create tasks, or review pipeline details before meetings. Use it for quick updates in chat or comprehensive CRM management, all grounded in your actual HubSpot data.","developerName":"HubSpot","category":"Productivity","capabilities":[],"websiteUrl":"https://www.hubspot.com/","privacyPolicyUrl":"https://legal.hubspot.com/privacy-policy","termsOfServiceUrl":"https://legal.hubspot.com/terms-of-service","defaultPrompt":["Create follow-up task to schedule meeting"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/hubspot/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/hubspot/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"keybid-puls@openai-curated","name":"keybid-puls","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/keybid-puls"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"KeyBid Puls","shortDescription":"Unlock the profitability of short-term rental investments with our ROI Calculator app, tailored for platfor...","longDescription":"Unlock the profitability of short-term rental investments with our ROI Calculator app, tailored for platforms like Airbnb, Booking.com, and VRBO. Users can paste property URLs from sites such as idealista.com, imobiliare.ro, storia.ro, and spitogatos.gr (with more integrations on the way), or upload screenshots from other real estate platforms. The app analyzes the data to deliver instant revenue projections, detailed reports, and a concise conclusion on whether the property is worth purchasing for short-term rentals. Covering 56 countries and over 191 cities, it supports multiple languages including English, Romanian, Spanish, and Greek for seamless global use. Ideal for property owners and investors seeking data-driven insights to evaluate vacation rental opportunities. Explore more at https://keybid.eu/keybid-puls.","developerName":"KeyBid","category":"Productivity","capabilities":[],"websiteUrl":"https://keybid.eu","privacyPolicyUrl":"https://keybid.eu/confidentialitate","termsOfServiceUrl":"https://keybid.eu/termeni","defaultPrompt":["Is this apartment worth buying for short-term"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/keybid-puls/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/keybid-puls/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"marcopolo@openai-curated","name":"marcopolo","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/marcopolo"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"MarcoPolo","shortDescription":"MarcoPolo spins up a secure container where Claude can work with your actual data.","longDescription":"MarcoPolo spins up a secure container where Claude can work with your actual data. Connect to your databases, APIs, S3, lakehouses, CRMs, Jira, logs and much more—using scoped credentials that are never exposed to the model. \n\nClaude gets DuckDB, Python, a shell, and a set of tools to explore, query, transform, and analyze data across systems. The workspace persists over time, so that you can build on your work. \n\nPrep a report, understand your data, debug an issue, or review the latest metrics right here in the conversation.","developerName":"Immersa, Inc.","category":"Coding","capabilities":[],"websiteUrl":"https://marcopolo.dev","privacyPolicyUrl":"https://marcopolo.dev/privacy-policy","termsOfServiceUrl":"https://marcopolo.dev/terms-and-conditions","defaultPrompt":["Available data sources to query or update"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/marcopolo/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/marcopolo/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"mem@openai-curated","name":"mem","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/mem"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Mem","shortDescription":"Give Codex the full context of your second brain by connecting your Mem knowledge base.","longDescription":"Give Codex the full context of your second brain by connecting your Mem knowledge base. Search your AI notebook for context, capture and recall ideas, save chats into new notes, edit and update living docs, and organize your AI workspace — simply by asking Codex. Use for: synthesizing and pulling actions items from meeting notes, deep research, personal knowledge management (PKM), knowledge repository building, task management, prioritization, and content development. Example prompts: \"Search my notes for pricing strategy and validate our thinking with research.\" \"Create a note from this chat and add it to our GTM collection.\" \"List all open tasks from this week's notes and add to my to-do list.\"","developerName":"Mem Labs, Inc.","category":"Productivity","capabilities":[],"websiteUrl":"https://mem.ai","privacyPolicyUrl":"https://get.mem.ai/pages/privacy","termsOfServiceUrl":"https://get.mem.ai/pages/terms-of-service","defaultPrompt":["Find the relevant notes in Mem"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/mem/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/mem/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"monday-com@openai-curated","name":"monday-com","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/monday-com"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Monday.com","shortDescription":"A powerful MCP connector enabling AI agents to seamlessly interact with monday.com.","longDescription":"A powerful MCP connector enabling AI agents to seamlessly interact with monday.com. This connector provides comprehensive access to monday.com features including board management, item operations, dashboards, and more, allowing AI assistants to help manage projects, gain insights, and automate workflows within monday.com.","developerName":"Monday.com","category":"Productivity","capabilities":[],"websiteUrl":"https://monday.com","privacyPolicyUrl":"https://monday.com/l/privacy/privacy-policy/","termsOfServiceUrl":null,"defaultPrompt":["Check the marketing campaign status in monday.com"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/monday-com/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/monday-com/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"moody-s@openai-curated","name":"moody-s","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/moody-s"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Moody's","shortDescription":"Credit and risk intelligence","longDescription":"Credit and risk intelligence","developerName":"Moody's","category":"Research","capabilities":[],"websiteUrl":null,"privacyPolicyUrl":null,"termsOfServiceUrl":null,"defaultPrompt":["Pull the latest Moody's context for this company"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/moody-s/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/moody-s/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"morningstar@openai-curated","name":"morningstar","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/morningstar"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Morningstar","shortDescription":"Investment and fund research","longDescription":"Investment and fund research","developerName":"Morningstar","category":"Research","capabilities":[],"websiteUrl":null,"privacyPolicyUrl":null,"termsOfServiceUrl":null,"defaultPrompt":["Summarize the Morningstar view on this asset"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/morningstar/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/morningstar/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"motherduck@openai-curated","name":"motherduck","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/motherduck"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"MotherDuck","shortDescription":"Connect AI assistants to your MotherDuck data warehouse.","longDescription":"Connect AI assistants to your MotherDuck data warehouse. Explore, visualize, and manage data using natural language–no SQL skills required. Create Dives: interactive visualizations that let you save and share answers with your team, staying up-to-date with your latest data. Works with real-world data without requiring semantic models or pre-configuration. Your AI assistant acts like a data analyst, exploring, validating, analyzing, and visualizing data iteratively to answer your questions.","developerName":"MotherDuck Corporation","category":"Productivity","capabilities":[],"websiteUrl":"https://motherduck.com/","privacyPolicyUrl":"https://motherduck.com/privacy-policy/","termsOfServiceUrl":"https://motherduck.com/terms-of-service/","defaultPrompt":["Show the top 30 customers by revenue last quarter"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/motherduck/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/motherduck/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"mt-newswires@openai-curated","name":"mt-newswires","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/mt-newswires"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"MT Newswires","shortDescription":"MT Newswires brings real-time global financial news directly into Codex — providing original, unbiased an...","longDescription":"MT Newswires brings real-time global financial news directly into Codex — providing original, unbiased and comprehensive multi-asset class coverage of capital markets and economies in over 180 topics.\n\nPowered by a global newsroom trusted by the largest banks, brokerages, professional trading, wealth management and research applications globally, every story is built for AI — so you get answers grounded in live market intelligence, not stale data.\n\nWhat you can do:\n• Get the latest news on any ticker and analyze price impact\n• Monitor energy sector developments across global equities \n• Track macro events and global central bank signals in real time\n• Screen for earnings, M&A, and market-moving headlines\n\nExample prompts:\n→ \"What is the latest news for NVIDIA and has it influenced the stock's price?\"\n→ \"Summarize the major analyst rating change developments from the past hour.\"\n→ \"What macro events are driving markets today?\"","developerName":"MT Newswires","category":"Research","capabilities":[],"websiteUrl":"https://www.mtnewswires.com","privacyPolicyUrl":"https://www.mtnewswires.com/privacy-policy","termsOfServiceUrl":"https://www.mtnewswires.com/subscriber-terms-of-service","defaultPrompt":["Summarize the latest MT Newswires updates on this company"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/mt-newswires/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/mt-newswires/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"myregistry-com@openai-curated","name":"myregistry-com","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/myregistry-com"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"MyRegistry.com","shortDescription":"MyRegistry.com helps make gift-giving easy for friends & family to get you the gifts you really want!","longDescription":"MyRegistry.com helps make gift-giving easy for friends & family to get you the gifts you really want! Create a universal gift list for weddings, baby showers, birthdays, or any celebration and add gifts from any store.","developerName":"MyRegistry.com","category":"Lifestyle","capabilities":[],"websiteUrl":"https://www.myregistry.com/","privacyPolicyUrl":"https://www.myregistry.com/Info/Privacy.aspx","termsOfServiceUrl":"https://www.myregistry.com/Info/terms.aspx","defaultPrompt":["Find the relevant registry details in MyRegistry.com"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/myregistry-com/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/myregistry-com/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"network-solutions@openai-curated","name":"network-solutions","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/network-solutions"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Network Solutions","shortDescription":"The Network Solutions Domain Search Assistant makes finding an available domain fast, simple, and conversat...","longDescription":"The Network Solutions Domain Search Assistant makes finding an available domain fast, simple, and conversational. Instead of searching one name at a time, users can describe their idea in plain language and instantly check domain availability across relevant extensions. The assistant helps refine names, suggest alternatives, and quickly identify options that are ready to register.\n\nBuilt to remove friction and frustration from domain discovery, this chat-powered experience keeps users moving forward when names are taken and surfaces smarter, brand-ready options in real time. Whether you’re launching a business, starting a personal project, or exploring new ideas, Network Solutions helps you go from concept to available domain with confidence.","developerName":"Network Solutions","category":"Productivity","capabilities":[],"websiteUrl":"https://www.networksolutions.com/","privacyPolicyUrl":"https://www.newfold.com/privacy-center","termsOfServiceUrl":"https://legal.newfold.com/TermsOfUse.pdf","defaultPrompt":["Searching for specific domain"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/network-solutions/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/network-solutions/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"omni-analytics@openai-curated","name":"omni-analytics","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/omni-analytics"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Omni Analytics","shortDescription":"Query Omni using the same semantic model, permissions, and logic defined by your data team directly from Codex.","longDescription":"Query Omni using the same semantic model, permissions, and logic defined by your data team directly from Codex. Allow internal teams to ask data questions in their AI workflows without logging into Omni directly, while still enforcing row-level security and business definitions.","developerName":"Omni Analytics","category":"Productivity","capabilities":[],"websiteUrl":"https://www.omni.co","privacyPolicyUrl":"https://omni.co/privacy","termsOfServiceUrl":"https://omni.co/terms","defaultPrompt":["Show me last year's orders by status"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/omni-analytics/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/omni-analytics/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"otter-ai@openai-curated","name":"otter-ai","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/otter-ai"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Otter.ai","shortDescription":"The Otter.ai MCP server connects Codex to your meeting intelligence, enabling search and retrieval of tra...","longDescription":"The Otter.ai MCP server connects Codex to your meeting intelligence, enabling search and retrieval of transcripts, summaries, action items, and meeting metadata directly within your workflow. Search meetings by keyword, date range, attendee, folder, or channel, then fetch full transcripts with speaker attribution. Use it to prepare for meetings by reviewing past discussions, extract decisions from historical conversations, or synthesize insights across your meeting archive. Supports both personal and enterprise Otter.ai workspaces.","developerName":"Otter.ai","category":"Productivity","capabilities":[],"websiteUrl":"https://otter.ai","privacyPolicyUrl":"https://otter.ai/privacy-policy","termsOfServiceUrl":"https://otter.ai/terms-of-service","defaultPrompt":["List recent meetings"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/otter-ai/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/otter-ai/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"particl-market-research@openai-curated","name":"particl-market-research","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/particl-market-research"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Particl Market Research","shortDescription":"Particl Market Research helps teams answer ecommerce research questions directly in Codex.","longDescription":"Particl Market Research helps teams answer ecommerce research questions directly in Codex. It supports company discovery, product catalog research, product detail and variant analysis, market leader discovery, market trend analysis, marketing asset discovery, retail event tracking, sales timeseries, and product mix breakdowns.\n\nThe app uses your authenticated Particl account and returns structured market intelligence data from Particl APIs.","developerName":"Particl","category":"Research","capabilities":[],"websiteUrl":"https://www.particl.com","privacyPolicyUrl":"https://www.particl.com/legal/privacy","termsOfServiceUrl":"https://www.particl.com/legal/terms","defaultPrompt":["Pull the relevant market snapshot from Particl"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/particl-market-research/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/particl-market-research/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"pipedrive@openai-curated","name":"pipedrive","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/pipedrive"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Pipedrive","shortDescription":"Connect to sync Pipedrive deals and contacts for use in Codex.","longDescription":"Connect to sync Pipedrive deals and contacts for use in Codex.","developerName":"OpenAI","category":"Productivity","capabilities":[],"websiteUrl":"https://www.pipedrive.com/","privacyPolicyUrl":"https://www.pipedrive.com/en/privacy","termsOfServiceUrl":null,"defaultPrompt":["Find the latest deal status in Pipedrive"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/pipedrive/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/pipedrive/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"pitchbook@openai-curated","name":"pitchbook","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/pitchbook"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"PitchBook","shortDescription":"PitchBook provides structured access to private capital market data across  companies, investors, funds, de...","longDescription":"PitchBook provides structured access to private capital market data across  companies, investors, funds, deals, limited partners, and people. It returns normalized fields such as  firmographics, financing rounds, deal terms, ownership information, financials, fund performance  metrics when available, LP commitments, investor portfolios, and team details with associated source  metadata. Use this connector when a query requires factual private market information or retrieval of  structured data related to private companies, investment activity, or market participants. It supports  queries that involve identifying entities, summarizing historical activity, or assembling datasets for  further analysis.","developerName":"PitchBook","category":"Research","capabilities":[],"websiteUrl":"https://www.pitchbook.com","privacyPolicyUrl":"https://www.pitchbook.com/privacy-policy","termsOfServiceUrl":"https://www.pitchbook.com/terms-of-use","defaultPrompt":["Use PitchBook to help with this task"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/pitchbook/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/pitchbook/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"policynote@openai-curated","name":"policynote","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/policynote"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"PolicyNote","shortDescription":"Use the PolicyNote app to access structured policy and regulatory intelligence from around the world.","longDescription":"Use the PolicyNote app to access structured policy and regulatory intelligence from around the world. Search legislation, regulatory actions, policy updates, and government activity across jurisdictions.\n\nThe app enables developers, analysts, and policy professionals to retrieve policy data programmatically and integrate it into internal tools, research workflows, dashboards, or monitoring systems. Queries return structured information about policy developments, government sources, and regulatory changes.\n\nPolicyNote helps teams track public policy activity, build alerts, power analysis tools, and integrate government intelligence into their applications.","developerName":"FiscalNote","category":"Research","capabilities":[],"websiteUrl":"https://fiscalnote.com/products/policynote-api","privacyPolicyUrl":"https://fiscalnote.com/privacy","termsOfServiceUrl":"https://data.policynote.com/terms","defaultPrompt":["Summarize the relevant policy context from PolicyNote"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/policynote/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/policynote/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"pylon@openai-curated","name":"pylon","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/pylon"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Pylon","shortDescription":"Access Pylon's customer support platform directly from Codex to search, manage, and resolve customer issues.","longDescription":"Access Pylon's customer support platform directly from Codex to search, manage, and resolve\ncustomer issues. Stay on top of your support queue while connecting Codex's insights to real customer conversations.\n\nYou can use the Pylon app to:\n  • Check your queue: \"What Pylon issues are assigned to me that need a response?\"\n  • Research customers: \"Summarize recent issues from Acme Corp and flag any escalations.\"\n  • Update issues: \"Mark the billing issue from Sarah as resolved and add a note that we issued a refund.\"","developerName":"Pylon Labs Inc.","category":"Productivity","capabilities":[],"websiteUrl":"https://www.usepylon.com/","privacyPolicyUrl":"https://www.usepylon.com/privacy","termsOfServiceUrl":"https://www.usepylon.com/terms","defaultPrompt":["Can you summarize my most recent issues"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/pylon/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/pylon/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"quartr@openai-curated","name":"quartr","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/quartr"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Quartr","shortDescription":"Access structured first-party IR data from over 14,500+ public companies across 65 markets Quartr delivers...","longDescription":"Access structured first-party IR data from over 14,500+ public companies across 65 markets Quartr delivers live and recorded earnings calls, real-time and historical transcripts with speaker identification, slide presentations, filings, reports, and event summaries. Best-in-class reliability and timeliness. Ideal for financial research, investment analysis, and building data-driven workflows on top of institutional-grade public company data.\n\nYou can use Quartr for:\n\nEarnings call analysis:\n\"List forward-looking statements for NVIDIA from recent transcripts and filings that reference expected progress or results in the upcoming earnings release.\"\n\nCompetitive intelligence:\n\"Compare how semiconductor companies talk about the same end markets and demand.\"\n\nKPI tracking:\n\"What KPIs has Spotify introduced, stopped emphasizing, or reframed across its last eight quarters?\"\n\nNarrative assessment:\n\"What were the most recurring themes in analyst questions during Eli Lilly's last two earnings calls? Highlight key areas of focus and concern.\"","developerName":"Quartr","category":"Research","capabilities":[],"websiteUrl":"https://quartr.com","privacyPolicyUrl":"https://quartr.com/terms-of-service/privacy-policy","termsOfServiceUrl":"https://quartr.com/terms-of-service","defaultPrompt":["Find the latest relevant Quartr materials"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/quartr/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/quartr/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"quicknode@openai-curated","name":"quicknode","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/quicknode"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Quicknode","shortDescription":"Manage your Quicknode infrastructure directly in OpenAI.","longDescription":"Manage your Quicknode infrastructure directly in OpenAI. Create and manage endpoints, monitor logs and usage, configure security and rate limits, and review billing from one conversation.","developerName":"Quicknode","category":"Coding","capabilities":[],"websiteUrl":"https://www.quicknode.com/","privacyPolicyUrl":"https://www.quicknode.com/privacy","termsOfServiceUrl":"https://www.quicknode.com/terms","defaultPrompt":["Use QuickNode to inspect the relevant chain data"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/quicknode/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/quicknode/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"ranked-ai@openai-curated","name":"ranked-ai","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/ranked-ai"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Ranked AI","shortDescription":"Ranked AI provides industry leading AI SEO & PPC software, with a fully managed service integrated into it.","longDescription":"Ranked AI provides industry leading AI SEO & PPC software, with a fully managed service integrated into it. We combine AI with industry veterans that know how to help you rank your website on traditional & AI search. Manage your traditional & AI search keywords, audits, backlinks, reports and more with our integrated app.","developerName":"Ranked AI, LLC","category":"Productivity","capabilities":[],"websiteUrl":"https://www.ranked.ai","privacyPolicyUrl":"https://www.ranked.ai/legal/privacy","termsOfServiceUrl":"https://www.ranked.ai/legal/terms","defaultPrompt":["Show rankings for project"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/ranked-ai/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/ranked-ai/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"razorpay@openai-curated","name":"razorpay","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/razorpay"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Razorpay","shortDescription":"Connect your Razorpay account to access your payment data through conversation.","longDescription":"Connect your Razorpay account to access your payment data through conversation.\nAsk Codex about your payments, orders, refunds, settlements, QR codes, payment links etc. Get instant answers to questions like \"Show me today's payments,\" \"What's the status of my recent settlements,\" or \"Find refunds from last week.\"\nPerfect for merchants who want quick insights without navigating dashboards. View transaction details, track settlement timelines, check saved payment methods, and analyze your payment activity—all through natural language.\n\nWhat you can do:\n1. Retrieve payment and order details\n2. Check refund and settlement status\n3. View QR code and payment link activity\n4. Track payouts and reconciliation data\n5. Access saved customer payment methods\n\nRead-only access—your data stays secure, and no transactions are executed through this app.","developerName":"Razorpay Software Private Limited","category":"Productivity","capabilities":[],"websiteUrl":"https://razorpay.com/","privacyPolicyUrl":"https://razorpay.com/privacy/","termsOfServiceUrl":"https://razorpay.com/terms/","defaultPrompt":["Check the relevant payment context in Razorpay"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/razorpay/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/razorpay/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"read-ai@openai-curated","name":"read-ai","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/read-ai"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Read AI","shortDescription":"Read AI brings your meeting intelligence directly into your AI workflows.","longDescription":"Read AI brings your meeting intelligence directly into your AI workflows. Connect your Read AI account to access meeting summaries, transcripts, action items, key questions, and more — all retrievable through natural conversation.\n\nRead AI can look up recent meetings, pull the full transcript from a specific call, surface action items from last week's syncs, or find what key questions came up in a discussion.\n\nWhat you can do:\n\n- Browse and filter your meetings by date range\n- Retrieve summaries, chapter breakdowns, and topics from any meeting\n- Pull action items and key questions to stay on top of follow-ups\n- Access full transcripts for deep dives or verbatim references\n\nWhether you're prepping for a follow-up, catching up on a meeting you missed, or building workflows around your recorded conversations, Read AI's MCP integration makes your meeting data a first-class part of your AI experience.","developerName":"Read AI, Inc","category":"Productivity","capabilities":[],"websiteUrl":"https://read.ai","privacyPolicyUrl":"https://www.read.ai/privacy-policy","termsOfServiceUrl":"https://www.read.ai/termsofservice","defaultPrompt":["Summarize the latest Read AI meeting insights"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/read-ai/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/read-ai/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"readwise@openai-curated","name":"readwise","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/readwise"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Readwise","shortDescription":"The official app for Readwise and Reader.","longDescription":"The official app for Readwise and Reader. \n\nThis app allows you to have Codex semantically search through all of your highlights, and any content saved to your Reader library.\n\nMore than that, it can do basically anything you can do in Reader! Triage your inbox, organize your library, catch up on your feed, and much more -- just ask :)","developerName":"Readwise Inc.","category":"Research","capabilities":[],"websiteUrl":"https://readwise.io","privacyPolicyUrl":"https://readwise.io/privacy","termsOfServiceUrl":"https://readwise.io/tos","defaultPrompt":["Find the most relevant highlights in Readwise"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/readwise/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/readwise/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"responsive@openai-curated","name":"responsive","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/responsive"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Responsive","shortDescription":"The Responsive App makes it easy to work with your organization’s data inside Codex.","longDescription":"The Responsive App makes it easy to work with your organization’s data inside Codex. Search your Content Library and generate responses so you can move faster with trusted information and without switching tools.","developerName":"RFPIO Inc. (d/b/a Responsive)","category":"Productivity","capabilities":[],"websiteUrl":"https://www.responsive.io","privacyPolicyUrl":"https://www.responsive.io/legal/privacy-policy","termsOfServiceUrl":"https://www.responsive.io/legal","defaultPrompt":["Pull the relevant proposal content from Responsive"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/responsive/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/responsive/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"scite@openai-curated","name":"scite","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/scite"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Scite","shortDescription":"Scite delivers answers grounded in peer-reviewed research you can verify.","longDescription":"Scite delivers answers grounded in peer-reviewed research you can verify. Each response is backed by real scientific sources, with citations that show how studies have been supported, disputed, or contextualized by other researchers. Behind the scenes, Scite’s proprietary citation-based ranking model prioritizes trustworthy, validated research, helping users move beyond claims to evidence.","developerName":"Scite","category":"Research","capabilities":[],"websiteUrl":"https://www.scite.ai","privacyPolicyUrl":"https://scite.ai/policy","termsOfServiceUrl":"https://scite.ai/terms","defaultPrompt":["What's latest research on impact of adolescent screen time"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/scite/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/scite/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"semrush@openai-curated","name":"semrush","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/semrush"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Semrush","shortDescription":"The Semrush MCP provides structured, quantitative SEO and traffic data for domains, keywords, backlinks, an...","longDescription":"The Semrush MCP provides structured, quantitative SEO and traffic data for domains, keywords, backlinks, and market-level audience insights. It returns factual datasets including domain analytics, keyword metrics, backlink profiles, traffic data across time periods and channels, geographic and demographic distributions, and competitive or industry-level indicators. The model should invoke this MCP whenever a user requests website metrics, traffic statistics, keyword data, competitor comparisons, or market/audience breakdowns that require authoritative data rather than inference. It should also be used when a user’s question requires data-driven evaluation of a specific domain, even if the query is phrased as advice or improvement guidance.","developerName":"Semrush Holdings, Inc.","category":"Productivity","capabilities":[],"websiteUrl":"https://www.semrush.com/","privacyPolicyUrl":"https://www.semrush.com/company/legal/privacy-policy/","termsOfServiceUrl":"https://www.semrush.com/company/legal/terms-of-service/","defaultPrompt":["Analyze traffic sources breakdown for nike.com"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/semrush/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/semrush/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"sendgrid@openai-curated","name":"sendgrid","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/sendgrid"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"SendGrid","shortDescription":"Connector for interacting with the SendGrid email API.","longDescription":"Connector for interacting with the SendGrid email API.","developerName":"OpenAI","category":"Coding","capabilities":[],"websiteUrl":"https://sendgrid.com/","privacyPolicyUrl":"https://www.twilio.com/legal/privacy","termsOfServiceUrl":null,"defaultPrompt":["Review email metrics and summarize deliverability"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/sendgrid/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/sendgrid/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"setu-bharat-connect-billpay@openai-curated","name":"setu-bharat-connect-billpay","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/setu-bharat-connect-billpay"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Setu Bharat Connect BillPay ","shortDescription":"This app helps you pay your utility bills through simple conversation.","longDescription":"This app helps you pay your utility bills through simple conversation. Instead of navigating apps or filling forms, you can just tell the assistant what you want to do—like paying your electricity, broadband, or other utility bills. The app finds the right biller, fetches the exact bill amount, and guides you through payment step by step. You can check pending bills, view bill amounts before paying, confirm whether a payment was successful and ask for a summary of your bill expenses. For steps that need extra care, such as verification or confirmation, the app clearly guides you through them so nothing happens without your approval. People like this app because it removes friction from routine bill payments. You don’t need to remember biller details or jump between screens—just ask, review, and pay, all in one conversation.","developerName":"Setu","category":"Lifestyle","capabilities":[],"websiteUrl":"https://setu.co/","privacyPolicyUrl":"https://setu.co/privacy-policy/","termsOfServiceUrl":"https://billpay-mcp.setu.co/termsandconditions","defaultPrompt":["Check the relevant bill payment context in Setu"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/setu-bharat-connect-billpay/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/setu-bharat-connect-billpay/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"signnow@openai-curated","name":"signnow","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/signnow"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"SignNow","shortDescription":"Get documents signed faster without switching between tools.","longDescription":"Get documents signed faster without switching between tools. The SignNow MCP server connects Codex directly to your SignNow account, letting you manage the entire eSignature workflow through conversation. Send signature requests, create documents from templates and pre-fill them, track invite statuses, and retrieve signed files — all by describing what you need in plain language. Whether you're handling contracts, agreements, or approvals, Codex handles the SignNow actions so you can focus on your work instead of chasing signatures.\n\nYou can use SignNow to:\n\nCreate and Send Documents:\n\"Create a document from the Employee NDA template and send it to client@example.com for signature\"\n\nTrack Signing Status:\n\"Check the signing status of the Sales Agreement and show me any pending signatures\"\n\nManage Templates:\n\"List all available templates and create a new contract from the Service Agreement template\"\n\nDownload Signed Documents:\n\"Get the download link for the completed Employment Contract\"","developerName":"airSlate Inc","category":"Productivity","capabilities":[],"websiteUrl":"https://www.signnow.com","privacyPolicyUrl":"https://legal.signnow.com/privacy-notice","termsOfServiceUrl":"https://legal.signnow.com/terms","defaultPrompt":["Check the status of the relevant SignNow document"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/signnow/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/signnow/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"skywatch@openai-curated","name":"skywatch","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/skywatch"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"SkyWatch","shortDescription":"Search and explore satellite imagery from top providers including Vantor, Planet, Airbus, and more, all in...","longDescription":"Search and explore satellite imagery from top providers including Vantor, Planet, Airbus, and more, all in one place. SkyWatch lets you find archive imagery by location, date, resolution, and cloud cover, compare pricing across providers, and browse available satellites and product offerings. Results include direct links to view and order imagery on SkyWatch Explore.","developerName":"SkyWatch Space Applications Inc.","category":"Productivity","capabilities":[],"websiteUrl":"https://skywatch.com","privacyPolicyUrl":"https://skywatch.com/privacy/","termsOfServiceUrl":"https://s3-us-west-2.amazonaws.com/skywatch-legal/SkyWatch+Terms+of+Service.pdf","defaultPrompt":["Find recent satellite images of the Golden Gate Bridge"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/skywatch/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/skywatch/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"statsig@openai-curated","name":"statsig","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/statsig"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Statsig","shortDescription":"Bring your Statsig workspace into Codex.","longDescription":"Bring your Statsig workspace into Codex. Product builders can now explore, manage, and create Statsig experiments, feature gates, dynamic configs, and more directly in Codex conversations.\n\nAsk things like:\n“Move this experiment to 50% rollout.”\n“Turn on this feature gate for all users.”\n“Show me which dynamic configs changed this week.”\n\"Explain how the DAU metric is defined.”\n\nYou can both read and write to Statsig: inspect experiment settings, read metric definitions, update allocations, toggle feature flags, edit targeting rules, and modify dynamic config values directly from Codex.\n\nThe app connects through Statsig’s MCP server and honors your existing Statsig permissions, so you only see and change what you’re authorized to access—across projects, environments, and teams.","developerName":"Statsig, LLC","category":"Coding","capabilities":[],"websiteUrl":"https://statsig.com","privacyPolicyUrl":"https://www.statsig.com/privacy","termsOfServiceUrl":"https://www.statsig.com/enterprise-terms","defaultPrompt":["Analyze results of Statsig experiment shorter_blog_titles"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/statsig/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/statsig/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"streak@openai-curated","name":"streak","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/streak"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Streak","shortDescription":"Streak is a CRM built directly into Gmail, so you can track deals, contacts, and workflows from your inbox.","longDescription":"Streak is a CRM built directly into Gmail, so you can track deals, contacts, and workflows from your inbox.\n\nEmails are logged automatically, pipelines update as conversations move forward, and notes and tasks stay attached to the work they belong to—without copying data into another tool.\n\nDesigned for teams and individuals who manage sales, partnerships, or customer relationships primarily over email and want a clear, up-to-date view of their work.","developerName":"Rewardly, Inc.","category":"Productivity","capabilities":[],"websiteUrl":"https://www.streak.com","privacyPolicyUrl":"https://www.streak.com/privacy","termsOfServiceUrl":"https://www.streak.com/terms","defaultPrompt":["Show recent deals in Streak"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/streak/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/streak/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"taxdown@openai-curated","name":"taxdown","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/taxdown"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Taxdown","shortDescription":"TaxDown te ayuda a resolver dudas fiscales en España, tanto para particulares como autónomos: deducciones,...","longDescription":"TaxDown te ayuda a resolver dudas fiscales en España, tanto para particulares como autónomos: deducciones, IRPF, renta y obligaciones fiscales, con respuestas claras y orientadas a tu caso.","developerName":"TAXDOWN S.L.","category":"Research","capabilities":[],"websiteUrl":"https://taxdown.es/","privacyPolicyUrl":"https://taxdown.es/politica-de-privacidad/","termsOfServiceUrl":"https://taxdown.es/terminos-condiciones/","defaultPrompt":["Summarize the relevant Taxdown status or guidance"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/taxdown/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/taxdown/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"teamwork-com@openai-curated","name":"teamwork-com","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/teamwork-com"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Teamwork.com","shortDescription":"Connect to sync Teamwork projects and tasks for use in Codex.","longDescription":"Connect to sync Teamwork projects and tasks for use in Codex.","developerName":"OpenAI","category":"Productivity","capabilities":[],"websiteUrl":"https://www.teamwork.com/","privacyPolicyUrl":"https://www.teamwork.com/privacy/","termsOfServiceUrl":null,"defaultPrompt":["Summarize the current Teamwork.com project status"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/teamwork-com/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/teamwork-com/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"third-bridge@openai-curated","name":"third-bridge","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/third-bridge"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Third Bridge","shortDescription":"Seamlessly incorporate critical context and trusted insights from industry experts as part of your financia...","longDescription":"Seamlessly incorporate critical context and trusted insights from industry experts as part of your financial and business analysis. Refocus on extracting high-quality, reliable information by querying Third Bridge’s best-in-class substantial Library of expert content and data.\n\nOur MCP systematically and securely instructs Large Language Models (LLMs) to query insights from our database into their systems, streamlining your workflows and improving your output.","developerName":"Third Bridge Group","category":"Research","capabilities":[],"websiteUrl":"https://www.thirdbridge.com","privacyPolicyUrl":"https://www.thirdbridge.com/en-us/about-us/compliance/policies/privacy-policy","termsOfServiceUrl":"https://www.thirdbridge.com/en-us/about-us/compliance/policies/third-bridge-mcp-pilot-terms","defaultPrompt":["Competitive analysis based on Third Bridge expert network"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/third-bridge/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/third-bridge/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"tinman-ai@openai-curated","name":"tinman-ai","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/tinman-ai"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Tinman AI","shortDescription":"Tinman AI helps loan officers and underwriters quickly underwrite home financing scenarios and answer compl...","longDescription":"Tinman AI helps loan officers and underwriters quickly underwrite home financing scenarios and answer complex eligibility questions using trusted credit decision data and underwriting logic. Instead of navigating fragmented systems, scattered guidelines, or manual spreadsheets, users can evaluate eligibility, DTI restructuring, and income calculations across a broad set of lenders and investors, instantly identifying which investors a loan qualifies for and why. Tinman AI turns what used to take days or weeks into real-time, compliant decisions that keep loans moving and deals alive.","developerName":"Better","category":"Research","capabilities":[],"websiteUrl":"https://better.com","privacyPolicyUrl":"https://better.com/about-us/privacy-policy","termsOfServiceUrl":"https://better.com/about-us/terms-of-use","defaultPrompt":["I have borrower at 52% DTI who wants HELOC w/ $450/month"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/tinman-ai/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/tinman-ai/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"united-rentals@openai-curated","name":"united-rentals","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/united-rentals"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"United Rentals","shortDescription":"Get the right equipment for the job without guesswork.","longDescription":"Get the right equipment for the job without guesswork. Share your project details and receive tailored equipment recommendations, along with specifications to support confident selection.","developerName":"United Rentals","category":"Productivity","capabilities":[],"websiteUrl":"https://www.unitedrentals.com","privacyPolicyUrl":"https://www.unitedrentals.com/legal/privacy-policy","termsOfServiceUrl":"https://www.unitedrentals.com/legal/website-terms-of-use-us-eng","defaultPrompt":["Find the relevant United Rentals inventory or availability"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/united-rentals/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/united-rentals/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"vantage@openai-curated","name":"vantage","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/vantage"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Vantage","shortDescription":"Vantage is a cloud observability and optimization platform that aggregates cloud infrastructure costs acros...","longDescription":"Vantage is a cloud observability and optimization platform that aggregates cloud infrastructure costs across providers to deliver a centralized view into total cloud spend. Vantage has multiple tools for optimizing cloud spend and provides organizations with advanced FinOps workflows and cost governance.","developerName":"Vantage","category":"Coding","capabilities":[],"websiteUrl":"https://www.vantage.sh","privacyPolicyUrl":"https://www.vantage.sh/legal/privacy-policy","termsOfServiceUrl":"https://www.vantage.sh/legal/service-agreement","defaultPrompt":["Summarize the current cloud cost picture in Vantage"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/vantage/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/vantage/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"waldo@openai-curated","name":"waldo","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/waldo"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Waldo","shortDescription":"Waldo is an AI-powered strategy platform for agencies and brands.","longDescription":"Waldo is an AI-powered strategy platform for agencies and brands. Run strategy agent, explore collected signals — paid ads, brand mentions, audience conversations, trending topics, and more — and retrieve data across your team's brand spaces.","developerName":"Curiosities, Inc.","category":"Productivity","capabilities":[],"websiteUrl":"https://www.waldo.fyi","privacyPolicyUrl":"https://www.waldo.fyi/privacy","termsOfServiceUrl":"https://www.waldo.fyi/tos","defaultPrompt":["Check the relevant mobile test coverage in Waldo"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/waldo/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/waldo/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"weatherpromise@openai-curated","name":"weatherpromise","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/weatherpromise"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"WeatherPromise","shortDescription":"Protect your trip with WeatherPromise and get back the full cost if it rains more than promised during your...","longDescription":"Protect your trip with WeatherPromise and get back the full cost if it rains more than promised during your vacation, automatically.\nTell us your destination, travel dates and trip cost and we'll show you an offer, personalized to your trip. Once you purchase the offer, your trip is protected.\nYou will get a link to your personal dashboard where you can monitor the weather during your trip. Rain is measured using independent, accurate data from official sources like NASA and NOAA.\nIf it rains more than the specified threshold, we'll email you automatically. Just confirm your details and the payment is sent right away, no additional proof required.\nGo on your trip and if it rains more than promised, you get a full refund, automatically.","developerName":"WeatherPromise, Inc.","category":"Lifestyle","capabilities":[],"websiteUrl":"https://www.weatherpromise.com/","privacyPolicyUrl":"https://www.weatherpromise.com/privacy","termsOfServiceUrl":"https://www.weatherpromise.com/terms","defaultPrompt":["Summarize the weather outlook from WeatherPromise"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/weatherpromise/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/weatherpromise/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"windsor-ai@openai-curated","name":"windsor-ai","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/windsor-ai"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Windsor.ai","shortDescription":"Windsor.ai connects your marketing and business data sources to Codex so you can ask questions in natural...","longDescription":"Windsor.ai connects your marketing and business data sources to Codex so you can ask questions in natural language and get answers from your connected accounts.\n\nCommon data sources customers connect include: Google Ads, Meta (Facebook) Ads, Instagram, LinkedIn Ads, LinkedIn Company Pages, TikTok Ads, GA4, Google Search Console, YouTube Analytics, Google Business Profile, HubSpot, Salesforce, Shopify, Klaviyo, Amazon Ads, Microsoft Ads (Bing), Google Merchant Center, Stripe, GoHighLevel, and more.  ￼","developerName":"Windsor.ai","category":"Productivity","capabilities":[],"websiteUrl":"https://windsor.ai","privacyPolicyUrl":"https://windsor.ai/privacy-statement/","termsOfServiceUrl":"https://windsor.ai/terms-of-service/","defaultPrompt":["Pull the relevant attribution context from Windsor.ai"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/windsor-ai/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/windsor-ai/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"yepcode@openai-curated","name":"yepcode","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/yepcode"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"YepCode","shortDescription":"YepCode lets you build custom AI tools using your own code with JSON Schema-defined inputs, executed in an...","longDescription":"YepCode lets you build custom AI tools using your own code with JSON Schema-defined inputs, executed in an isolated sandbox with access to any npm or PyPI package and secure environment variables.\n\nDefine reusable processes in Node.js or Python, expose them as callable AI tools, and execute them on demand or on a schedule. Every run is logged and auditable, enabling traceable, production-grade AI integrations.\n\nBuilt for developers who need programmable, observable AI tool execution.","developerName":"YepCode S.L.","category":"Coding","capabilities":[],"websiteUrl":"https://yepcode.io/","privacyPolicyUrl":"https://yepcode.io/privacy/","termsOfServiceUrl":"https://yepcode.io/terms-of-use/","defaultPrompt":["Find the relevant YepCode workflow context"],"brandColor":null,"composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/yepcode/assets/app-icon.png","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/yepcode/assets/app-icon.png","logoUrl":null,"screenshots":[],"screenshotUrls":[]}},{"id":"render@openai-curated","name":"render","source":{"type":"local","path":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/render"},"installed":false,"enabled":false,"installPolicy":"AVAILABLE","authPolicy":"ON_INSTALL","interface":{"displayName":"Render","shortDescription":"Deploy, debug, monitor, and migrate apps on Render.","longDescription":"Provides skills for deploying apps with Blueprints, debugging failed deploys, monitoring service health and metrics, building Render Workflows, and migrating from Heroku.","developerName":"Render","category":"Coding","capabilities":["Interactive","Write"],"websiteUrl":"https://render.com/","privacyPolicyUrl":"https://render.com/privacy","termsOfServiceUrl":"https://render.com/terms","defaultPrompt":["How are my Render services doing?","Help me validate my render.yaml for Render.","Debug a failed Render deployment."],"brandColor":"#8A05FF","composerIcon":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plugins/render/assets/logo.svg","composerIconUrl":null,"logo":"/private/tmp/amux-live-codex-home.OEIOVR/.tmp/plugins/plu