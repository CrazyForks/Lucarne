OUT {"id":12,"result":{"data":[{"cwd":"/private/var/folders/rb/bzdrr2hj3x7db9mrc56chs440000gn/T/.tmpqbCrUC","skills":[{"name":"browser-use:browser","description":"Use the Codex in-app browser to inspect, navigate, test, or automate local targets such as localhost, 127.0.0.1, ::1, file://, or the current in-app browser tab.","interface":{"displayName":"Browser Use","shortDescription":"Use Browser for Codex in-app browser (IAB) local targets such as localhost, 127.0.0.1, ::1, and file://.","iconSmall":null,"iconLarge":null,"brandColor":null,"defaultPrompt":"Inspect the current in-app browser tab or open a local app in the in-app browser and verify it."},"path":"/Users/era/.codex/plugins/cache/openai-bundled/browser-use/0.1.0-alpha1/skills/browser/SKILL.md","scope":"user","enabled":true},{"name":"design-taste-frontend","description":"Senior UI/UX Engineer. Architect digital interfaces overriding default LLM biases. Enforces metric-based rules, strict component architecture, CSS hardware acceleration, and balanced design engineering.","path":"/Users/era/.codex/skills/taste-skill/SKILL.md","scope":"user","enabled":true},{"name":"documents:documents","description":"Create, edit, redline, and comment on `.docx` files inside the container, with a strict render-and-verify workflow. Use `render_docx.py` to generate page PNGs (and optional PDF) for visual QA, then iterate until layout is flawless before delivering the final DOCX.","interface":{"displayName":"Documents","shortDescription":"Create and edit document files","iconSmall":"/Users/era/.codex/plugins/cache/openai-primary-runtime/documents/26.426.12240/skills/documents/assets/file-document.png","iconLarge":"/Users/era/.codex/plugins/cache/openai-primary-runtime/documents/26.426.12240/skills/documents/assets/file-document.png","brandColor":"#2563EB","defaultPrompt":"Use $documents to create, edit, redline, or review a document file."},"path":"/Users/era/.codex/plugins/cache/openai-primary-runtime/documents/26.426.12240/skills/documents/SKILL.md","scope":"user","enabled":true},{"name":"find-skills","description":"Helps users discover and install agent skills when they ask questions like \"how do I do X\", \"find a skill for X\", \"is there a skill that can...\", or express interest in extending capabilities. This skill should be used when the user is looking for functionality that might exist as an installable skill.","path":"/Users/era/.cc-switch/skills/find-skills/SKILL.md","scope":"user","enabled":true},{"name":"frontend-design","description":"Create distinctive, production-grade frontend interfaces with high design quality. Use this skill when the user asks to build web components, pages, artifacts, posters, or applications (examples include websites, landing pages, dashboards, React components, HTML/CSS layouts, or when styling/beautifying any web UI). Generates creative, polished code and UI design that avoids generic AI aesthetics.","path":"/Users/era/.cc-switch/skills/frontend-design/SKILL.md","scope":"user","enabled":true},{"name":"github:gh-address-comments","description":"Address actionable GitHub pull request review feedback. Use when the user wants to inspect unresolved review threads, requested changes, or inline review comments on a PR, then implement selected fixes. Use the GitHub app for PR metadata and flat comment reads, and use the bundled GraphQL script via `gh` whenever thread-level state, resolution status, or inline review context matters.","interface":{"displayName":"Review Follow-up","shortDescription":"Address actionable PR feedback","iconSmall":"/Users/era/.codex/plugins/cache/openai-curated/github/886026e9/skills/gh-address-comments/assets/github-small.svg","iconLarge":"/Users/era/.codex/plugins/cache/openai-curated/github/886026e9/skills/gh-address-comments/assets/github.png","brandColor":null,"defaultPrompt":"Use $gh-address-comments to review unresolved pull request feedback, implement the selected fixes, and summarize what changed."},"path":"/Users/era/.codex/plugins/cache/openai-curated/github/886026e9/skills/gh-address-comments/SKILL.md","scope":"user","enabled":true},{"name":"github:gh-fix-ci","description":"Use when a user asks to debug or fix failing GitHub PR checks that run in GitHub Actions. Use the GitHub app from this plugin for PR metadata and patch context, and use `gh` for Actions check and log inspection before implementing any approved fix.","interface":{"displayName":"CI Debug","shortDescription":"Debug failing GitHub Actions checks","iconSmall":"/Users/era/.codex/plugins/cache/openai-curated/github/886026e9/skills/gh-fix-ci/assets/github-small.svg","iconLarge":"/Users/era/.codex/plugins/cache/openai-curated/github/886026e9/skills/gh-fix-ci/assets/github.png","brandColor":null,"defaultPrompt":"Use $gh-fix-ci to inspect the failing GitHub Actions checks on this PR, summarize the root cause, and propose the smallest viable fix."},"path":"/Users/era/.codex/plugins/cache/openai-curated/github/886026e9/skills/gh-fix-ci/SKILL.md","scope":"user","enabled":true},{"name":"github:github","description":"Triage and orient GitHub repository, pull request, and issue work through the connected GitHub app. Use when the user asks for general GitHub help, wants PR or issue summaries, or needs repository context before choosing a more specific GitHub workflow.","interface":{"displayName":"GitHub","shortDescription":"Inspect PRs, issues, CI, and publish flows","iconSmall":"/Users/era/.codex/plugins/cache/openai-curated/github/886026e9/skills/github/assets/github-small.svg","iconLarge":"/Users/era/.codex/plugins/cache/openai-curated/github/886026e9/skills/github/assets/github.png","brandColor":null,"defaultPrompt":"Use $github to inspect pull requests and issues, orient the repository context, and choose the right GitHub workflow."},"path":"/Users/era/.codex/plugins/cache/openai-curated/github/886026e9/skills/github/SKILL.md","scope":"user","enabled":true},{"name":"github:yeet","description":"Publish local changes to GitHub by confirming scope, committing intentionally, pushing the branch, and opening a draft PR through the GitHub app from this plugin, with `gh` used only as a fallback where connector coverage is insufficient.","interface":{"displayName":"Publish Changes","shortDescription":"Commit, push, and open a PR","iconSmall":"/Users/era/.codex/plugins/cache/openai-curated/github/886026e9/skills/yeet/assets/yeet-small.svg","iconLarge":"/Users/era/.codex/plugins/cache/openai-curated/github/886026e9/skills/yeet/assets/yeet.png","brandColor":null,"defaultPrompt":"Use $yeet to confirm the intended changes, create a focused commit, push it, and open a draft pull request."},"path":"/Users/era/.codex/plugins/cache/openai-curated/github/886026e9/skills/yeet/SKILL.md","scope":"user","enabled":true},{"name":"presentations:Presentations","description":"Create, edit, render, verify, and export PowerPoint slide decks. Use when Codex needs to build or modify a deck, presentation deck, slide deck, slides, PowerPoint, PPT, PPTX, or .pptx file.","interface":{"displayName":"Presentations","shortDescription":"Create and edit presentation slide decks","iconSmall":"/Users/era/.codex/plugins/cache/openai-primary-runtime/presentations/26.426.12240/skills/presentations/assets/file-presentation.png","iconLarge":"/Users/era/.codex/plugins/cache/openai-primary-runtime/presentations/26.426.12240/skills/presentations/assets/file-presentation.png","brandColor":"#C43E1C","defaultPrompt":"Create a presentation slide deck with $Presentations."},"path":"/Users/era/.codex/plugins/cache/openai-primary-runtime/presentations/26.426.12240/skills/presentations/SKILL.md","scope":"user","enabled":true},{"name":"spreadsheets:Spreadsheets","description":"Use this skill when a user requests to create, modify, analyze, visualize, or work with spreadsheet files (`.xlsx`, `.xls`, `.csv`, `.tsv`) with formulas, formatting, charts, tables, and recalculation.","interface":{"displayName":"Spreadsheets","shortDescription":"Create and edit spreadsheet or excel files","iconSmall":"/Users/era/.codex/plugins/cache/openai-primary-runtime/spreadsheets/26.426.12240/skills/spreadsheets/assets/file-spreadsheet.png","iconLarge":"/Users/era/.codex/plugins/cache/openai-primary-runtime/spreadsheets/26.426.12240/skills/spreadsheets/assets/file-spreadsheet.png","brandColor":"#107C41","defaultPrompt":"Use $Spreadsheets to build or update a spreadsheet artifact with formulas, formatting, and verification."},"path":"/Users/era/.codex/plugins/cache/openai-primary-runtime/spreadsheets/26.426.12240/skills/spreadsheets/SKILL.md","scope":"user","enabled":true},{"name":"superpowers:brainstorming","description":"You MUST use this before any creative work - creating features, building components, adding functionality, or modifying behavior. Explores user intent, requirements and design before implementation.","path":"/Users/era/.codex/superpowers/skills/brainstorming/SKILL.md","scope":"user","enabled":true},{"name":"superpowers:dispatching-parallel-agents","description":"Use when facing 2+ independent tasks that can be worked on without shared state or sequential dependencies","path":"/Users/era/.codex/superpowers/skills/dispatching-parallel-agents/SKILL.md","scope":"user","enabled":true},{"name":"superpowers:executing-plans","description":"Use when you have a written implementation plan to execute in a separate session with review checkpoints","path":"/Users/era/.codex/superpowers/skills/executing-plans/SKILL.md","scope":"user","enabled":true},{"name":"superpowers:finishing-a-development-branch","description":"Use when implementation is complete, all tests pass, and you need to decide how to integrate the work - guides completion of development work by presenting structured options for merge, PR, or cleanup","path":"/Users/era/.codex/superpowers/skills/finishing-a-development-branch/SKILL.md","scope":"user","enabled":true},{"name":"superpowers:receiving-code-review","description":"Use when receiving code review feedback, before implementing suggestions, especially if feedback seems unclear or technically questionable - requires technical rigor and verification, not performative agreement or blind implementation","path":"/Users/era/.codex/superpowers/skills/receiving-code-review/SKILL.md","scope":"user","enabled":true},{"name":"superpowers:requesting-code-review","description":"Use when completing tasks, implementing major features, or before merging to verify work meets requirements","path":"/Users/era/.codex/superpowers/skills/requesting-code-review/SKILL.md","scope":"user","enabled":true},{"name":"superpowers:subagent-driven-development","description":"Use when executing implementation plans with independent tasks in the current session","path":"/Users/era/.codex/superpowers/skills/subagent-driven-development/SKILL.md","scope":"user","enabled":true},{"name":"superpowers:systematic-debugging","description":"Use when encountering any bug, test failure, or unexpected behavior, before proposing fixes","path":"/Users/era/.codex/superpowers/skills/systematic-debugging/SKILL.md","scope":"user","enabled":true},{"name":"superpowers:test-driven-development","description":"Use when implementing any feature or bugfix, before writing implementation code","path":"/Users/era/.codex/superpowers/skills/test-driven-development/SKILL.md","scope":"user","enabled":true},{"name":"superpowers:using-git-worktrees","description":"Use when starting feature work that needs isolation from current workspace or before executing implementation plans - creates isolated git worktrees with smart directory selection and safety verification","path":"/Users/era/.codex/superpowers/skills/using-git-worktrees/SKILL.md","scope":"user","enabled":true},{"name":"superpowers:using-superpowers","description":"Use when starting any conversation - establishes how to find and use skills, requiring Skill tool invocation before ANY response including clarifying questions","path":"/Users/era/.codex/superpowers/skills/using-superpowers/SKILL.md","scope":"user","enabled":true},{"name":"superpowers:verification-before-completion","description":"Use when about to claim work is complete, fixed, or passing, before committing or creating PRs - requires running verification commands and confirming output before making any success claims; evidence before assertions always","path":"/Users/era/.codex/superpowers/skills/verification-before-completion/SKILL.md","scope":"user","enabled":true},{"name":"superpowers:writing-plans","description":"Use when you have a spec or requirements for a multi-step task, before touching code","path":"/Users/era/.codex/superpowers/skills/writing-plans/SKILL.md","scope":"user","enabled":true},{"name":"superpowers:writing-skills","description":"Use when creating new skills, editing existing skills, or verifying skills work before deployment","path":"/Users/era/.codex/superpowers/skills/writing-skills/SKILL.md","scope":"user","enabled":true},{"name":"ui-ux-pro-max","description":"UI/UX design intelligence. 50 styles, 21 palettes, 50 font pairings, 20 charts, 9 stacks (React, Next.js, Vue, Svelte, SwiftUI, React Native, Flutter, Tailwind, shadcn/ui). Actions: plan, build, create, design, implement, review, fix, improve, optimize, enhance, refactor, check UI/UX code. Projects: website, landing page, dashboard, admin panel, e-commerce, SaaS, portfolio, blog, mobile app, .html, .tsx, .vue, .svelte. Elements: button, modal, navbar, sidebar, card, table, form, chart. Styles: glassmorphism, claymorphism, minimalism, brutalism, neumorphism, bento grid, dark mode, responsive, skeuomorphism, flat design. Topics: color palette, accessibility, animation, layout, typography, font pairing, spacing, hover, shadow, gradient. Integrations: shadcn/ui MCP for component search and examples.","path":"/Users/era/.codex/skills/ui-ux-pro-max/SKILL.md","scope":"user","enabled":true},{"name":"web-access:web-access","description":"所有联网操作必须通过此 skill 处理，包括：搜索、网页抓取、登录后操作、网络交互等。 触发场景：用户要求搜索信息、查看网页内容、访问需要登录的网站、操作网页界面、抓取社交媒体内容（小红书、微博、推特等）、读取动态渲染页面、以及任何需要真实浏览器环境的网络任务。","path":"/Users/era/.codex/skills/web-access/SKILL.md","scope":"user","enabled":true},{"name":"web-design-guidelines","description":"Review UI code for Web Interface Guidelines compliance. Use when asked to \"review my UI\", \"check accessibility\", \"audit design\", \"review UX\", or \"check my site against best practices\".","path":"/Users/era/.cc-switch/skills/web-design-guidelines/SKILL.md","scope":"user","enabled":true},{"name":"imagegen","description":"Generate or edit raster images when the task benefits from AI-created bitmap visuals such as photos, illustrations, textures, sprites, mockups, or transparent-background cutouts. Use when Codex should create a brand-new image, transform an existing image, or derive visual variants from references, and the output should be a bitmap asset rather than repo-native code or vector. Do not use when the task is better handled by editing existing SVG/vector/code-native assets, extending an established icon or logo system, or building the visual directly in HTML/CSS/canvas.","interface":{"displayName":"Image Gen","shortDescription":"Generate or edit images for websites, games, and more","iconSmall":"/Users/era/.codex/skills/.system/imagegen/assets/imagegen-small.svg","iconLarge":"/Users/era/.codex/skills/.system/imagegen/assets/imagegen.png","brandColor":null,"defaultPrompt":"Use $imagegen to make or edit an image for this project."},"path":"/Users/era/.codex/skills/.system/imagegen/SKILL.md","scope":"system","enabled":true},{"name":"openai-docs","description":"Use when the user asks how to build with OpenAI products or APIs and needs up-to-date official documentation with citations, help choosing the latest model for a use case, or model upgrade and prompt-upgrade guidance; prioritize OpenAI docs MCP tools, use bundled references only as helper context, and restrict any fallback browsing to official OpenAI domains.","interface":{"displayName":"OpenAI Docs","shortDescription":"Reference official OpenAI docs, including upgrade guidance","iconSmall":"/Users/era/.codex/skills/.system/openai-docs/assets/openai-small.svg","iconLarge":"/Users/era/.codex/skills/.system/openai-docs/assets/openai.png","brandColor":null,"defaultPrompt":"Look up official OpenAI docs, load relevant GPT-5.4 upgrade references when applicable, and answer with concise, cited guidance."},"dependencies":{"tools":[{"type":"mcp","value":"openaiDeveloperDocs","description":"OpenAI Developer Docs MCP server","transport":"streamable_http","url":"https://developers.openai.com/mcp"}]},"path":"/Users/era/.codex/skills/.system/openai-docs/SKILL.md","scope":"system","enabled":false},{"name":"plugin-creator","description":"Create and scaffold plugin directories for Codex with a required `.codex-plugin/plugin.json`, optional plugin folders/files, and baseline placeholders you can edit before publishing or testing. Use when Codex needs to create a new local plugin, add optional plugin structure, or generate or update repo-root `.agents/plugins/marketplace.json` entries for plugin ordering and availability metadata.","interface":{"displayName":"Plugin Creator","shortDescription":"Scaffold plugins and marketplace entries","iconSmall":"/Users/era/.codex/skills/.system/plugin-creator/assets/plugin-creator-small.svg","iconLarge":"/Users/era/.codex/skills/.system/plugin-creator/assets/plugin-creator.png","brandColor":null,"defaultPrompt":"Use $plugin-creator to scaffold a plugin with placeholder plugin.json, optional structure, and a marketplace.json entry."},"path":"/Users/era/.codex/skills/.system/plugin-creator/SKILL.md","scope":"system","enabled":false},{"name":"skill-creator","description":"Guide for creating effective skills. This skill should be used when users want to create a new skill (or update an existing skill) that extends Codex's capabilities with specialized knowledge, workflows, or tool integrations.","shortDescription":"Create or update a skill","interface":{"displayName":"Skill Creator","shortDescription":"Create or update a skill","iconSmall":"/Users/era/.codex/skills/.system/skill-creator/assets/skill-creator-small.svg","iconLarge":"/Users/era/.codex/skills/.system/skill-creator/assets/skill-creator.png","brandColor":null,"defaultPrompt":null},"path":"/Users/era/.codex/skills/.system/skill-creator/SKILL.md","scope":"system","enabled":false},{"name":"skill-installer","description":"Install Codex skills into $CODEX_HOME/skills from a curated list or a GitHub repo path. Use when a user asks to list installable skills, install a curated skill, or install a skill from another repo (including private repos).","shortDescription":"Install curated skills from openai/skills or other repos","interface":{"displayName":"Skill Installer","shortDescription":"Install curated skills from openai/skills or other repos","iconSmall":"/Users/era/.codex/skills/.system/skill-installer/assets/skill-installer-small.svg","iconLarge":"/Users/era/.codex/skills/.system/skill-installer/assets/skill-installer.png","brandColor":null,"defaultPrompt":null},"path":"/Users/era/.codex/skills/.system/skill-installer/SKILL.md","scope":"system","enabled":true}],"errors":[]}]}}
