,10,54,50,56,58,104,105,103,104,108,105,103,104,116,95,111,118,101,114,108,97,121,115,95,98,111,114,100,101,114,32,61,32,102,97,108,115,101,32,32,32,32,32,35,32,104,105,103,104,108,105,103,104,116,32,101,120,116,101,110,100,115,32,111,118,101,114,32,115,101,108,101,99,116,105,111,110,32,98,111,120,32,98,111,114,100,101,114,10,55,56,57,58,87,104,101,110,32,116,104,101,32,115,97,109,101,32,115,101,114,118,101,114,32,110,97,109,101,32,105,115,32,100,101,102,105,110,101,100,32,98,121,32,109,111,114,101,32,116,104,97,110,32,111,110,101,32,115,111,117,114,99,101,44,32,105,116,32,105,115,32,114,101,115,111,108,118,101,100,32,105,110,32,116,104,105,115,32,111,114,100,101,114,32,40,104,105,103,104,101,115,116,32,112,114,105,111,114,105,116,121,32,102,105,114,115,116,41,58,10,60,47,119,111,114,107,115,112,97,99,101,95,114,101,115,117,108,116,62],"stderr":[],"exit_code":0,"match_count":31,"file_matches":[{"path":"/private/var/folders/rb/bzdrr2hj3x7db9mrc56chs440000gn/T/.tmpFSxEpj/.grok-home/docs/user-guide/05-configuration.md","matches":[{"line_number":9,"content":"Configuration is resolved in this order (highest priority first):"},{"line_number":11,"content":"1. **CLI flags** (e.g., `--yolo`, `--model`, `--sandbox`)"},{"line_number":31,"content":"[models]"},{"line_number":32,"content":"default = \"grok-build\"           # model used for new sessions"},{"line_number":33,"content":"web_search = \"grok-4.20-multi-agent\"   # model used by the web_search tool"},{"line_number":35,"content":"# Defaults applied to every model; a per-model [model.<id>] value always wins."},{"line_number":36,"content":"# See \"Custom Models\" for the per-model overrides and full details."},{"line_number":48,"content":"max_thoughts_width = 120               # max column width for reasoning display"},{"line_number":62,"content":"remote_fetch = true                    # model-catalog + remote-settings fetches from xAI backends (default: true;"},{"line_number":103,"content":"the approval menu highlights one row by default — the cursor row. The"},{"line_number":233,"content":"Add custom model endpoints to use alternative providers or self-hosted models."},{"line_number":236,"content":"[model.my-model]"},{"line_number":237,"content":"model = \"model-id\"                    # model identifier sent to API"},{"line_number":239,"content":"name = \"Display Name\"                 # shown in model picker"},{"line_number":251,"content":"Override built-in models by using their name as the section key:"},{"line_number":254,"content":"[model.grok-build]"},{"line_number":265,"content":"args = [\"-y\", \"@modelcontextprotocol/server-github\"]"},{"line_number":274,"content":"args = [\"-y\", \"@modelcontextprotocol/server-postgres\", \"postgresql://user:pass@localhost/db\"]"},{"line_number":308,"content":"model = \"embedding-beta-3-small\"      # embedding model"},{"line_number":322,"content":"[subagents.models]"},{"line_number":323,"content":"explore = \"grok-build\"               # route to different models"},{"line_number":326,"content":"To pin the model a subagent uses, set its entry under `[subagents.models]`."},{"line_number":356,"content":"Each cell can also be toggled via environment variable (highest precedence) or remote feature flag (lowest). See the environment-variables reference for the env var names. Resolution order: env var > config.toml > feature flag > default (on)."},{"line_number":419,"content":"| `title.items` | array | (see above) | Items shown in the title bar. Options: `action-required`, `spinner`, `activity`, `session-name`, `cwd`, `model`, `turn-timer`, `grok`. |"},{"line_number":518,"content":"The same `[telemetry]` table also configures the **external OpenTelemetry stream** — an independent opt-in (it does not require the telemetry toggle above) that ships a curated, content-free usage schema to your *own* OTLP collector. Collector auth is supplied via `OTEL_EXPORTER_OTLP_HEADERS` and is never stored on disk. See [Monitoring & Usage](24-monitoring-usage.md) for the full schema, env vars, and privacy model."},{"line_number":544,"content":"[models]"},{"line_number":547,"content":"[model.company-grok]"},{"line_number":548,"content":"model = \"grok-build\""},{"line_number":589,"content":"mouse_hover = true                    # show hover highlight on the prompt widget"},{"line_number":628,"content":"highlight_overlays_border = false     # highlight extends over selection box border"},{"line_number":789,"content":"When the same server name is defined by more than one source, it is resolved in this order (highest priority first):"}]}]}},"_meta":{"totalTokens":21279,"eventId":"019f4fb2-9914-7191-a376-cce109321c40-93","agentTimestampMs":1783748571649,"promptId":"88ba2cab-a08b-42d2-91e3-2335c5d0098c","streamStartMs":1783748570209,"turnStartMs":1783748566486,"updateType":"ToolCallUpdate","updateParams":{"toolCallId":"call-8636c92b-3c01-446a-b76f-60768a32e204-5","status":"Completed"}}}}
