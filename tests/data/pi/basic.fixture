# Pi RPC basic conversation fixture
EXPECT_IN_CONTAINS "get_state"
OUT {"id":"0","type":"response","command":"get_state","success":true,"data":{"sessionId":"s1","sessionFile":"/tmp/pi-test-session.jsonl"}}
EXPECT_IN_CONTAINS "prompt"
OUT {"type":"agent_start"}
OUT {"type":"message_update","assistantMessageEvent":{"type":"thinking_delta","delta":"Inspecting "}}
OUT {"type":"message_update","assistantMessageEvent":{"type":"text_delta","delta":"Hello "}}
OUT {"type":"tool_execution_start","toolCallId":"t1","toolName":"read","args":{"path":"/tmp/test.txt"}}
OUT {"type":"tool_execution_end","toolCallId":"t1","result":"file contents","isError":false}
OUT {"type":"turn_end","message":{"role":"assistant","content":[{"type":"text","text":"Hello from Pi"}],"usage":{"input":10,"output":5,"cacheRead":2,"cost":{"total":0.001}}}}
EXIT 0
